{
  "hooks": {
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.ai-os/hooks/stop-hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.ai-os/hooks/post-tool-log.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.ai-os/hooks/post-tool-use.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(gemini -p *)",
      "mcp__vibe-check-mcp__run_vibe_audit",
      "mcp__vibe-check-mcp__run_chaos_test",
      "mcp__vibe-check-mcp__get_performance_metrics",
      "mcp__intent-refiner-mcp__refine_intent",
      "mcp__intent-refiner-mcp__write_update_md",
      "mcp__task-synchronizer-mcp__get_state",
      "mcp__task-synchronizer-mcp__add_task",
      "mcp__task-synchronizer-mcp__update_task_status",
      "mcp__task-synchronizer-mcp__add_stamp",
      "mcp__task-synchronizer-mcp__set_project_focus",
      "mcp__task-synchronizer-mcp__sync_tasks",
      "mcp__task-synchronizer-mcp__append_tasks",
      "mcp__task-synchronizer-mcp__verify_markdown_sync",
      "mcp__task-synchronizer-mcp__archive_done_tasks",
      "mcp__safe-exec-mcp__analyze_command",
      "mcp__blueprint-aligner-mcp__align_diff",
      "mcp__blueprint-aligner-mcp__validate_blueprint_section",
      "mcp__blueprint-aligner-mcp__generate_implementation_delta",
      "mcp__context-guardian-mcp__check_workspace",
      "mcp__risk-analyzer-mcp__classify_risk",
      "mcp__risk-analyzer-mcp__get_tier_actions",
      "mcp__context-invoker-mcp__activate_skill",
      "mcp__context-invoker-mcp__activate_agent",
      "mcp__archive-manager-mcp__check_context_health",
      "mcp__archive-manager-mcp__execute_archive",
      "mcp__orchestrator-mcp__run_preflight",
      "mcp__orchestrator-mcp__run_handover",
      "mcp__orchestrator-mcp__run_review",
      "mcp__memory-manager-mcp__export_signature",
      "mcp__memory-manager-mcp__query_signatures",
      "mcp__verification-mcp__verify_compliance"
    ]
  }
}
