# AI-OS v2 environment variables
# Copy this file to .env and fill in real values. .env is gitignored.

# ── Optional: Anthropic Claude API (for direct API integration) ──────────────
ANTHROPIC_API_KEY=

# ── Optional: Google Gemini API (used by advisor-mcp A2A bridge) ─────────────
# advisor-mcp invokes the `gemini` CLI; the CLI reads its own auth.
# Set this only if you call the API directly elsewhere.
GEMINI_API_KEY=

# ── Optional: TestSprite MCP ─────────────────────────────────────────────────
# Used by .mcp.json TestSprite entry. Required for ai test workflows.
TESTSPRITE_API_KEY=

# ── Optional: Claude Code thinking budget (E-7) ──────────────────────────────
# Set to "0" for standard speed, or a positive integer for extended thinking.
CLAUDE_THINKING_BUDGET_TOKENS=0

# ── Optional: GitHub PAT for github-bridge-mcp ───────────────────────────────
# Only needed if `gh auth login` cannot be used.
GH_TOKEN=
