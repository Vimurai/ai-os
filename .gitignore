src/templates/.mcp.json
.env
.env.local
*.key
*.pem

# Node modules — root and nested workspaces
/node_modules
**/node_modules

# Project-scoped Gemini settings contain machine-specific absolute paths
.gemini/settings.json

# SQLite WAL/SHM sidecar files (must not be committed; can be half-flushed)
.ai/state.sqlite-shm
.ai/state.sqlite-wal
*.sqlite-shm
*.sqlite-wal

# TestSprite generated artifacts
testsprite_tests/

# E-31: Auto-generated skill index — regenerated by `ai sync` on every run.
# Tracking causes spurious diffs from sort-order/description changes.
**/_SKILLS_INDEX.md

# E-110: Auto-generated blueprint index — regenerated by `ai sync` from the
# .ai/blueprints/*.md set (which churns as the Architect adds blueprints), so
# tracking it would break on clean checkouts. Same rationale as _SKILLS_INDEX.md.
.ai/blueprints/_INDEX.md
