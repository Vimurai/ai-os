src/templates/.mcp.json
.env
.env.local
*.key
*.pem

# Node modules — root and nested workspaces
/node_modules
**/node_modules

# Project-scoped Gemini settings contain machine-specific absolute paths
.gemini/settings.json

# E-133 (antigravity-migration): Antigravity workspace MCP config generated by
# `ai provider add agy` — holds machine-specific absolute paths + a TestSprite
# API_KEY env slot, so it is gitignored (blueprint §Security).
.agents/mcp_config.json

# E-156 (test-harness-isolation): ephemeral test MCP config. tests/run.sh writes
# it inside a private temp dir and a trap removes it on exit; this is a safety net
# in case a suite ever drops one at the repo root.
.mcp.test.json

# SQLite WAL/SHM sidecar files (must not be committed; can be half-flushed)
.ai/state.sqlite-shm
.ai/state.sqlite-wal
*.sqlite-shm
*.sqlite-wal

# TestSprite generated artifacts
testsprite_tests/

# E-31: Auto-generated skill index — regenerated by `ai sync` on every run.
# Tracking causes spurious diffs from sort-order/description changes.
**/_SKILLS_INDEX.md

# E-110: Auto-generated blueprint index — regenerated by `ai sync` from the
# .ai/blueprints/*.md set (which churns as the Architect adds blueprints), so
# tracking it would break on clean checkouts. Same rationale as _SKILLS_INDEX.md.
.ai/blueprints/_INDEX.md

# E-118: Interactive Bridge runtime signal queue — written by handoff_control
# and consumed by `ai watch` at runtime. Pure ephemeral state (like a .pid), so
# it must never be tracked. Rollback per interactive-bridge.md: safe to delete.
.ai/signal.json

# E-140: native Antigravity subagent manifests — regenerated by `ai sync --agents`
.agents/agents/

# Interactive Bridge runtime lock (ephemeral, like signal.json) — never track.
.ai/.ai-watch.lock/

# E-145 (self-learning-arc): Memory Palace runtime artifacts — the candidate index
# (palace-index.json, refreshed each `ai sync`), the embeddings, and the multimodal-RAG
# dead-letter queue. All regenerated; never tracked.
.ai/memory/
