#!/usr/bin/env bash
set -euo pipefail

AIOS="${HOME}/.ai-os"
VERSION="3.2"

usage() {
  cat <<USAGE
ai — AI-OS v${VERSION}

Commands:
  ai install          Install configs to ~/.gemini + ~/.claude + ~/.config/github-copilot; enable agent teams; set up hooks
  ai init             Create/upgrade .ai/ in current repo (safe, no overwrite)
  ai onboard          Print the Principal Architect reverse-engineering prompt for existing repos
  ai update [--force] Prepare UPDATE.md + print TSRT-tiered session prompt (Gate 1)
  ai preflight        Print DIGEST-first read order + SESSION stamp template
  ai review <who> [--tier <1|2|3>]  Print tier-aware critic prompts (auto-detects tier)
  ai test [--vibe]    Run automated tests (TestSprite) or Vibe/Chaos audit (--vibe)
  ai mcp-setup        Install npm dependencies for all AI-OS MCP servers
  ai archive          Move old LOG/COMM/REVIEWS entries to .ai/archive/YYYY-MM/
  ai digest           Print prompt to regenerate DIGEST.md (run when stale)
  ai sync             Re-sync agent/skill files from ~/.ai-os to ~/.claude, ~/.gemini, ~/.config/github-copilot
  ai migrate-state [--force]  Seed state.json from TASKS.md (run once after v3 upgrade)
  ai doctor           Diagnose PATH, config, hooks, MCP, Copilot CLI
  ai where            Print install paths
  ai version          Print version
USAGE
}

# ── helpers ──────────────────────────────────────────────────────────────────

ensure_file_if_missing() {
  local src="$1" dst="$2"
  if [[ ! -f "$dst" ]]; then
    cp "$src" "$dst"
  fi
}

# Generates .mcp.json with absolute paths to ~/.ai-os/mcp/<server>/index.js
# Uses registry.json as source of truth. Preserves user-set env values.
generate_mcp_json() {
  local DEST_DIR="${1:-.}"
  local REGISTRY="${AIOS}/config/registry.json"
  local MCP_FILE="${DEST_DIR}/.mcp.json"

  if ! command -v python3 &>/dev/null; then
    [[ -f "${AIOS}/templates/.mcp.json" ]] && cp "${AIOS}/templates/.mcp.json" "$MCP_FILE"
    return
  fi

  python3 - "$REGISTRY" "$MCP_FILE" "$HOME" "$AIOS" <<'PY'
import json, sys, os
registry_path, mcp_path, home, aios = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]

servers = {
  "filesystem": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-filesystem@2026.1.14", "."],
    "description": "Scoped filesystem access — enforces CAPABILITIES.md path restrictions. Restricts to project root by default."
  },
  "memory": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-memory@2026.1.26"],
    "description": "Knowledge-graph memory store. Queryable alternative/supplement to DIGEST.md for semantic lookups."
  },
  "TestSprite": {
    "command": "npx",
    "args": ["@testsprite/testsprite-mcp@latest"],
    "env": {"API_KEY": "your-testsprite-api-key"},
    "description": "TestSprite MCP — AI-powered test generation and verification. Third brain in the Tripartite Engine (Plan->Build->Test)."
  }
}

if os.path.exists(registry_path):
    with open(registry_path) as f:
        reg = json.load(f)
    for name, info in reg.get("mcp_servers", {}).items():
        if "path" in info:
            abs_path = os.path.join(aios, "mcp", name, "index.js")
            servers[name] = {"command": "node", "args": [abs_path]}

# Preserve user-set env values from existing .mcp.json (e.g. real TestSprite API key)
if os.path.exists(mcp_path):
    try:
        with open(mcp_path) as f:
            existing = json.load(f)
        for name, cfg in existing.get("mcpServers", {}).items():
            if name in servers and "env" in cfg:
                env = cfg["env"]
                if env.get("API_KEY", "").strip() not in ("", "your-testsprite-api-key"):
                    servers[name].setdefault("env", {}).update(env)
    except Exception:
        pass

with open(mcp_path, "w") as f:
    json.dump({"mcpServers": servers}, f, indent=2)
    f.write("\n")
PY
}

ensure_ai_templates() {
  mkdir -p .ai .ai/archive

  local T="${AIOS}/templates"

  ensure_file_if_missing "$T/RULES.md"         ".ai/RULES.md"
  ensure_file_if_missing "$T/SEED.md"          ".ai/SEED.md"
  ensure_file_if_missing "$T/DIGEST.md"        ".ai/DIGEST.md"
  ensure_file_if_missing "$T/BRIEF.md"         ".ai/BRIEF.md"
  ensure_file_if_missing "$T/TASKS.md"         ".ai/TASKS.md"
  ensure_file_if_missing "$T/UPDATE.md"        ".ai/UPDATE.md"
  ensure_file_if_missing "$T/LOG.md"           ".ai/LOG.md"
  ensure_file_if_missing "$T/architect.md.template" ".ai/architect.md"
  ensure_file_if_missing "$T/state.json"          ".ai/state.json"

  # .gitignore for sensitive .ai/ files
  if [[ ! -f ".ai/.gitignore" ]]; then
    cp "$T/_gitignore" ".ai/.gitignore"
    echo "Created .ai/.gitignore (review it — sensitive files excluded from git)"
  fi

  # .mcp.json in project root — generated with absolute paths to ~/.ai-os/mcp/
  if [[ ! -f ".mcp.json" ]]; then
    generate_mcp_json "."
    echo "Created .mcp.json (MCP servers: filesystem + memory + AI-OS custom servers)"
  fi

  # .github/copilot-instructions.md — read automatically by GitHub Copilot Chat
  local C="${AIOS}/copilot"
  if [[ -f "${C}/copilot-instructions.md" && ! -f ".github/copilot-instructions.md" ]]; then
    mkdir -p .github
    cp "${C}/copilot-instructions.md" ".github/copilot-instructions.md"
    echo "Created .github/copilot-instructions.md (fill in project-specific Copilot context)"
  fi
}

migrate_legacy_ai_if_present() {
  local legacy=0
  for f in MASTER.md HANDOFF.md OWNERSHIP.md RUNBOOK.md 00_context.md 01_repo_state.md 05_input.md 50_acceptance.md 40_implementation_log.md; do
    [[ -f ".ai/$f" ]] && legacy=1 && break
  done
  if [[ $legacy -eq 1 ]]; then
    mkdir -p .ai/legacy
    for f in MASTER.md HANDOFF.md OWNERSHIP.md RUNBOOK.md 00_context.md 01_repo_state.md 05_input.md 50_acceptance.md 40_implementation_log.md; do
      [[ -f ".ai/$f" ]] && mv ".ai/$f" ".ai/legacy/$f"
    done
    { echo ""; echo "## Legacy migration ($(date '+%Y-%m-%d'))"; echo "- Moved legacy .ai files to .ai/legacy/"; echo "- Review and copy relevant content into BRIEF/TASKS/REPO."; } >> .ai/MIGRATION.md
    echo "Legacy .ai files moved to .ai/legacy/ — review MIGRATION.md"
  fi
}

enable_claude_agent_teams() {
  mkdir -p "${HOME}/.claude"
  python3 - <<'PY'
import json, os, sys
path = os.path.expanduser("~/.claude/settings.json")
data = {}
if os.path.exists(path):
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f) or {}
    except Exception as e:
        print(f"WARN: ~/.claude/settings.json is not valid JSON ({e}). Fix it, then re-run: ai install")
        sys.exit(0)

# Enable agent teams
env = data.setdefault("env", {})
env["CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS"] = "1"

# Tighten Gemini permission: replace broad Bash(gemini *) with scoped Bash(gemini -p *)
perms = data.setdefault("permissions", {})
allow = perms.get("allow", [])
# Replace any "Bash(gemini *)" with scoped version
new_allow = []
for entry in allow:
    if entry == "Bash(gemini *)":
        new_allow.append("Bash(gemini -p *)")
        print("Tightened: Bash(gemini *) → Bash(gemini -p *)")
    else:
        new_allow.append(entry)
# Add scoped gemini permission if not present at all
if "Bash(gemini -p *)" not in new_allow and "Bash(gemini *)" not in new_allow:
    new_allow.append("Bash(gemini -p *)")
    print("Added: Bash(gemini -p *)")
perms["allow"] = new_allow

# E-35: Auto-enable AI-OS MCP tool permissions (registry-driven)
_reg_path = os.path.expanduser("~/.ai-os/config/registry.json")
if os.path.exists(_reg_path):
    with open(_reg_path) as _rf:
        _reg = json.load(_rf)
    for _srv, _info in _reg.get("mcp_servers", {}).items():
        if "path" not in _info:
            continue
        for _tool in _info.get("allowed-tools", []):
            if _tool == "*":
                continue
            _perm = f"mcp__{_srv}__{_tool}"
            if _perm not in new_allow:
                new_allow.append(_perm)
                print(f"Added MCP permission: {_perm}")

# Add hooks
hooks = data.setdefault("hooks", {})

# Stop hook — auto SESSION stamp + DIGEST update trigger
stop_cmd = "bash $HOME/.ai-os/hooks/stop-hook.sh"
stop_hooks = hooks.setdefault("Stop", [])
already = any(
    h.get("command") == stop_cmd
    for entry in stop_hooks
    for h in entry.get("hooks", [])
)
if not already:
    stop_hooks.append({"matcher": ".*", "hooks": [{"type": "command", "command": stop_cmd}]})
    print("Added Stop hook: auto SESSION stamp")

# PostToolUse — auto LOG append
post_cmd = "bash $HOME/.ai-os/hooks/post-tool-log.sh"
post_hooks = hooks.setdefault("PostToolUse", [])
already = any(
    h.get("command") == post_cmd
    for entry in post_hooks
    for h in entry.get("hooks", [])
)
if not already:
    post_hooks.append({"matcher": "Write|Edit", "hooks": [{"type": "command", "command": post_cmd}]})
    print("Added PostToolUse hook: auto LOG append")

# Metadata
data["ai_os"] = {"installed_by": "ai-os", "version": "3.2"}

with open(path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
print("settings.json updated ✓")
PY
}

configure_gemini_mcp() {
  local REGISTRY="${AIOS}/config/registry.json"
  mkdir -p "${HOME}/.gemini"
  python3 - "$REGISTRY" "$HOME" "$AIOS" <<'PY'
import json, os, sys

registry_path, home, aios = sys.argv[1], sys.argv[2], sys.argv[3]
path = os.path.join(home, ".gemini", "settings.json")

# Base npm-managed servers (not path-based, shared between Claude and Gemini)
servers = {
    "filesystem": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem@2026.1.14", os.getcwd()]
    },
    "memory": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-memory@2026.1.26"]
    }
}

# Registry-driven custom servers (same source of truth as generate_mcp_json)
if os.path.exists(registry_path):
    with open(registry_path) as f:
        reg = json.load(f)
    for name, info in reg.get("mcp_servers", {}).items():
        if "path" in info:
            abs_path = os.path.join(aios, "mcp", name, "index.js")
            servers[name] = {"command": "node", "args": [abs_path]}

data = {}
if os.path.exists(path):
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f) or {}
    except Exception as e:
        print(f"WARN: {path} is not valid JSON ({e}). Recreating.")

data["mcpServers"] = servers

with open(path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write("\n")
print("~/.gemini/settings.json MCP config updated ✓")
PY
}

install_global() {
  echo "Preparing fresh AI-OS v2 installation..."
  
  # Destructive fresh install: remove old config to ensure v2 alignment
  rm -rf "${HOME}/.gemini"
  rm -rf "${HOME}/.claude"
  rm -rf "${HOME}/.config/github-copilot"
  echo "✓ Old configurations cleared"

  # Gemini (Principal Architect)
  mkdir -p "${HOME}/.gemini/agents" "${HOME}/.gemini/skills" "${HOME}/.gemini/commands"
  cp -f "${AIOS}/gemini/GEMINI.md"      "${HOME}/.gemini/GEMINI.md"
  cp -f "${AIOS}/gemini/agents/"*.md    "${HOME}/.gemini/agents/" 2>/dev/null || true
  sync_skills_20 "${AIOS}/shared/skills" "${HOME}/.gemini/skills"
  sync_skills_20 "${AIOS}/gemini/skills" "${HOME}/.gemini/skills"
  cp -f "${AIOS}/gemini/commands/"*.toml "${HOME}/.gemini/commands/" 2>/dev/null || true
  configure_gemini_mcp
  echo "✓ Installed Gemini (Principal Architect) config → ~/.gemini"

  # Claude (Principal Software Engineer)
  mkdir -p "${HOME}/.claude/agents" "${HOME}/.claude/skills"
  cp -f "${AIOS}/claude/CLAUDE.md"      "${HOME}/.claude/CLAUDE.md"
  cp -f "${AIOS}/claude/agents/"*.md    "${HOME}/.claude/agents/" 2>/dev/null || true
  sync_skills_20 "${AIOS}/shared/skills" "${HOME}/.claude/skills"
  sync_skills_20 "${AIOS}/claude/skills" "${HOME}/.claude/skills"
  echo "✓ Installed Claude (Principal Software Engineer) config → ~/.claude"

  # Copilot CLI
  mkdir -p "${HOME}/.config/github-copilot"
  if [[ -f "${AIOS}/copilot/COPILOT.md" ]]; then
    cp -f "${AIOS}/copilot/COPILOT.md" "${HOME}/.config/github-copilot/COPILOT.md"
  fi
  echo "✓ Installed Copilot config → ~/.config/github-copilot"
  
  if command -v gh &>/dev/null && gh extension list 2>/dev/null | grep -q "github/gh-copilot"; then
    gh copilot config set telemetry false 2>/dev/null || true
    echo "  gh copilot: configured ✓ (telemetry off)"
  else
    echo "  gh copilot: not installed — Recommended: gh extension install github/gh-copilot"
  fi

  # Hooks
  chmod +x "${AIOS}/hooks/"*.sh 2>/dev/null || true
  echo "✓ Hooks ready → ${AIOS}/hooks"

  # Copy MCP servers to ~/.ai-os/mcp/ (source already at AIOS since we ARE the install)
  if [[ -d "${AIOS}/mcp" ]]; then
    echo "✓ MCP servers available → ${AIOS}/mcp"
  fi

  # Install MCP server npm dependencies
  if command -v node &>/dev/null; then
    echo "Setting up MCP server dependencies..."
    do_mcp_setup 2>/dev/null || echo "  ⚠  MCP setup: some servers failed — run: ai mcp-setup"
  else
    echo "  ⚠  Node.js not found — MCP setup skipped. Install Node.js then run: ai mcp-setup"
  fi

  # Enable agent teams + fix permissions + add v2 hooks
  enable_claude_agent_teams
}

install_git_hooks() {
  local GIT_HOOKS_DIR
  GIT_HOOKS_DIR="$(git rev-parse --git-dir 2>/dev/null)/hooks"
  if [[ -z "$GIT_HOOKS_DIR" || ! -d "$GIT_HOOKS_DIR" ]]; then
    echo "  ⚠  Not a git repo — skipping git hook install"
    return
  fi

  local HOOK_SRC="${AIOS}/hooks/pre-commit.sh"
  local HOOK_DST="${GIT_HOOKS_DIR}/pre-commit"

  if [[ ! -f "$HOOK_SRC" ]]; then
    echo "  ⚠  pre-commit.sh not found at ${HOOK_SRC} — run: ai install"
    return
  fi

  if [[ -f "$HOOK_DST" ]]; then
    # Check if it's already the AI-OS hook
    if grep -q "AI-OS Gate 2" "$HOOK_DST" 2>/dev/null; then
      echo "  ✓ pre-commit hook already installed (Gate 2)"
      return
    else
      # Preserve existing hook — chain it
      local BACKUP="${HOOK_DST}.pre-aios"
      mv "$HOOK_DST" "$BACKUP"
      echo "  ✓ Backed up existing pre-commit hook → pre-commit.pre-aios"
      # Write wrapper that calls both
      cat > "$HOOK_DST" <<WRAPPER
#!/usr/bin/env bash
# AI-OS pre-commit wrapper — calls original hook then AI-OS Gate 2
bash "\$(dirname "\$0")/pre-commit.pre-aios" || exit 1
bash "${HOOK_SRC}" || exit 1
WRAPPER
    fi
  else
    cp "$HOOK_SRC" "$HOOK_DST"
  fi

  chmod +x "$HOOK_DST"
  echo "  ✓ Installed Gate 2 (Quality Gate) pre-commit hook → ${HOOK_DST}"

  # E-55: Install post-commit hook (TASKS.md auto-sync)
  local PC_SRC="${AIOS}/hooks/post-commit.sh"
  local PC_DST="${GIT_HOOKS_DIR}/post-commit"

  if [[ ! -f "$PC_SRC" ]]; then
    echo "  ⚠  post-commit.sh not found at ${PC_SRC} — run: ai install"
    return
  fi

  if [[ -f "$PC_DST" ]]; then
    if grep -q "AI-OS.*TASK-SYNC\|TASKS.md Auto-Sync" "$PC_DST" 2>/dev/null; then
      echo "  ✓ post-commit hook already installed (TASK-SYNC)"
      return
    else
      # Chain with existing hook
      local PC_BACKUP="${PC_DST}.pre-aios"
      mv "$PC_DST" "$PC_BACKUP"
      echo "  ✓ Backed up existing post-commit hook → post-commit.pre-aios"
      cat > "$PC_DST" <<WRAPPER
#!/usr/bin/env bash
# AI-OS post-commit wrapper — calls original hook then AI-OS TASK-SYNC
bash "\$(dirname "\$0")/post-commit.pre-aios" || true
bash "${PC_SRC}" || true
WRAPPER
    fi
  else
    cp "$PC_SRC" "$PC_DST"
  fi

  chmod +x "$PC_DST"
  echo "  ✓ Installed TASK-SYNC post-commit hook → ${PC_DST}"
}

do_init() {
  ensure_ai_templates
  migrate_legacy_ai_if_present
  install_git_hooks

  # E-33: Auto-setup MCP server dependencies (Battery-Included onboarding)
  if command -v node &>/dev/null && [[ -d "${AIOS}/mcp" ]]; then
    echo ""
    echo "Setting up MCP servers (Node.js detected)..."
    do_mcp_setup 2>/dev/null || echo "  ⚠  MCP setup incomplete — run: ai mcp-setup"
  else
    echo ""
    echo "MCP servers: Node.js not found — run 'ai mcp-setup' after installing Node.js"
  fi

  # E-93: Structured-First init — seed state.json from TASKS.md automatically
  if [[ -f ".ai/TASKS.md" ]]; then
    echo ""
    echo "Seeding state.json from TASKS.md (Structured-First init)..."
    do_migrate_state --force 2>/dev/null || echo "  ⚠  State migration incomplete — run: ai migrate-state --force"
  fi

  echo ""
  echo "Initialized .ai/ + .github/ (safe — no overwrites) with AI-OS v${VERSION}"
  echo ""
  echo "Next (MANDATORY):"
  echo "1) Fill in .ai/BRIEF.md and .ai/REPO.md"
  echo "2) Fill in .ai/DIGEST.md — Include Triad Health (Planning/Execution/Testing)"
  echo "3) Define the initial vision in .ai/architect.md (Template provided)"
  echo "4) Fill in .github/copilot-instructions.md (project-specific context)"
  echo "5) ai update     — start a peer agent session"
  echo ""
  echo "Triad Workflow:"
  echo "  Architect (Gemini) → Writes to architect.md / Planning docs"
  echo "  Engineer (Claude)  → Implements code based on blueprints"
  echo "  Tester (TestSprite) → Mandatory quality gate via 'ai test'"
  echo ""
  echo "MCP servers enabled in .mcp.json (filesystem + memory)."
}

# ── TSRT: Tier classifier (bash-native, no MCP dependency) ──────────────────
# Reads UPDATE.md + staged diff, returns 1/2/3 via stdout.
# Used by do_update and do_review for gate skipping.
detect_tier() {
  local UPDATE_FILE=".ai/UPDATE.md"
  local CONTENT=""
  local DIFF=""

  [[ -f "$UPDATE_FILE" ]] && CONTENT=$(cat "$UPDATE_FILE" 2>/dev/null || true)

  # Try staged diff first, fall back to working tree diff
  DIFF=$(git diff --staged 2>/dev/null || true)
  [[ -z "$DIFF" ]] && DIFF=$(git diff HEAD 2>/dev/null || true)

  local COMBINED="${CONTENT} ${DIFF}"

  # Tier 3 signals — high-risk keywords
  if echo "$COMBINED" | grep -qiE \
    '\b(auth|oauth|jwt|secret|api.?key|token|password|credential|deploy|production|migration|breaking.?change|rbac|permission|role|access.?control|encryption|new.?feature|new.?service)\b'; then
    echo "3"; return
  fi

  # Tier 3 file signals — sensitive file patterns in diff
  if echo "$DIFF" | grep -qE '^\+\+\+ b/.*(auth|login|password|secret|\.env|migration|deploy|release|package\.json|credential|security|permission|token)'; then
    echo "3"; return
  fi

  # Tier 1 signals — only docs/style/typo
  if echo "$COMBINED" | grep -qiE '\b(typo|css|style|color|font|spacing|docs?|documentation|readme|comment|changelog|format|lint|prettier)\b'; then
    # Only Tier 1 if there are no Tier 2 signals
    if ! echo "$COMBINED" | grep -qiE '\b(refactor|logic|api|endpoint|model|database|test|implement|config|algorithm|function|class|method)\b'; then
      echo "1"; return
    fi
  fi

  # Tier 1 file signals — only non-source files changed
  if [[ -n "$DIFF" ]]; then
    local NON_TIER1
    NON_TIER1=$(echo "$DIFF" | grep '^\+\+\+ b/' | grep -vE '\.(css|scss|less|md|txt|json)$|README|docs?/' || true)
    if [[ -z "$NON_TIER1" ]]; then
      echo "1"; return
    fi
  fi

  # Default: Tier 2
  echo "2"
}

# ── Gate 1: Intent Gate ───────────────────────────────────────────────────────
# Returns: 0 = pass, 1 = vague (hard block), 2 = high-risk (soft block / warning)
intent_gate() {
  local UPDATE_FILE=".ai/UPDATE.md"
  local HASH_FILE=".ai/.update.hash"

  [[ ! -f "$UPDATE_FILE" ]] && return 0

  # Strip template placeholder lines to get real user content
  local CONTENT
  CONTENT=$(grep -v '^#' "$UPDATE_FILE" \
    | grep -v '^$' \
    | grep -v '^Write a small delta' \
    | grep -v '^Then run Claude' \
    | grep -v '^Clear this file' \
    | grep -v '^- Add:' \
    | grep -v '^- Modify:' \
    | grep -v '^- Remove:' \
    | grep -v '^Constraints:' \
    || true)

  # Empty → separate warning path (handled below)
  [[ -z "$CONTENT" ]] && return 0

  # ── Change detection ─────────────────────────────────────────────────────
  local CURRENT_HASH
  CURRENT_HASH=$(md5 -q "$UPDATE_FILE" 2>/dev/null \
                  || md5sum "$UPDATE_FILE" 2>/dev/null | cut -d' ' -f1 \
                  || echo "")
  local PREV_HASH=""
  [[ -f "$HASH_FILE" ]] && PREV_HASH=$(cat "$HASH_FILE")

  if [[ -n "$CURRENT_HASH" && "$CURRENT_HASH" == "$PREV_HASH" ]]; then
    # Unchanged since last session — skip gate re-analysis (token saver)
    return 0
  fi
  # Persist new hash regardless of gate outcome
  [[ -n "$CURRENT_HASH" ]] && echo "$CURRENT_HASH" > "$HASH_FILE"

  # ── Vagueness detection ───────────────────────────────────────────────────
  local WORD_COUNT
  WORD_COUNT=$(echo "$CONTENT" | wc -w | tr -d ' ')

  local HAS_ACTION=0
  echo "$CONTENT" | grep -qiE \
    '\b(add|implement|fix|create|update|refactor|remove|delete|migrate|deploy|build|write|change|replace|integrate|scaffold|install|configure|test|debug|review|audit)\b' \
    && HAS_ACTION=1

  # VOTU OVERRIDE: Long, structured Architect-led content (>20 words + action verb) passes the
  # vagueness gate. A verbose-but-vague input still requires an action verb to proceed.
  if [[ $WORD_COUNT -gt 20 && $HAS_ACTION -eq 1 ]]; then
    return 0
  fi

  # Hard-block: < 8 words OR no action verb at all
  if [[ $WORD_COUNT -lt 8 || $HAS_ACTION -eq 0 ]]; then
    cat >&2 <<VAGUE
╔══════════════════════════════════════════════════════════════════════════╗
║  AI-OS GATE 1: INTENT GATE — VAGUE INTENT DETECTED (BLOCKED)           ║
╠══════════════════════════════════════════════════════════════════════════╣
║  UPDATE.md is too vague for safe execution (${WORD_COUNT} words, no action verb). ║
║  Clarify intent before starting a session.                               ║
╚══════════════════════════════════════════════════════════════════════════╝

Clarification required — answer these in .ai/UPDATE.md:
  1. What specific component/file/system is the target?
  2. What is the desired outcome (concrete acceptance criteria)?
  3. Is this Tier 1 (docs/style), Tier 2 (logic), or Tier 3 (auth/infra)?

Paste into Gemini (prd_writer) to refine intent:
  "Refine this into structured TASKS.md P-## entries:
   $(echo "$CONTENT" | head -3)"

VAGUE
    return 1
  fi

  # ── High-risk detection (Tier 3) ─────────────────────────────────────────
  local IS_HIGH_RISK=0
  echo "$CONTENT" | grep -qiE \
    '\b(auth|oauth|jwt|secret|api.?key|token|password|credential|passphrase|env.var|deploy|production|migration|breaking.?change|drop.?table|delete.?all|rm -rf|truncate)\b' \
    && IS_HIGH_RISK=1

  if [[ $IS_HIGH_RISK -eq 1 ]]; then
    cat >&2 <<HIGHRISK
╔══════════════════════════════════════════════════════════════════════════╗
║  AI-OS GATE 1: INTENT GATE — HIGH-RISK INTENT DETECTED (TIER 3)        ║
╠══════════════════════════════════════════════════════════════════════════╣
║  UPDATE.md contains high-risk keywords (auth/deploy/secrets/migration). ║
║  Architect (Gemini) review is required before execution begins.          ║
╚══════════════════════════════════════════════════════════════════════════╝

Before executing, verify:
  ✓ This change is covered by an existing blueprint in .ai/architect.md
  ✓ A P-## task has been created by the Architect for this work
  ✓ [SEC_CLEARED] tag has been added to .ai/LOG.md after threat model

Paste into Gemini for Architect review:
  "Audit this Tier 3 intent for security implications and create a P-## task:
   $(echo "$CONTENT" | head -3)"

⚠  Proceeding without Architect sign-off violates the Security Architecture.
   Add [SEC_CLEARED] to .ai/LOG.md to acknowledge and continue.

HIGHRISK
    return 2
  fi

  return 0
}

do_update() {
  local FORCE=0
  local VOTU=0
  for arg in "$@"; do
    [[ "$arg" == "--force" || "$arg" == "-f" ]] && FORCE=1
    [[ "$arg" == "--votu" ]] && VOTU=1
  done

  # E-92: VOTU — Voice of the User: capture chat log and refine into UPDATE.md
  if [[ "$VOTU" -eq 1 ]]; then
    if [[ ! -d ".ai" ]]; then
      echo "✗ No .ai/ directory found. Run: ai init"
      exit 1
    fi
    echo "━━ [VOTU] VOICE OF THE USER INTAKE ━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   Paste your chat log below. Press Ctrl-D when done."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    local CHAT_LOG
    CHAT_LOG=$(cat)
    if [[ -z "$CHAT_LOG" ]]; then
      echo "✗ No input received. Aborting."
      exit 1
    fi
    python3 - "$CHAT_LOG" <<'PY'
import sys, re
from datetime import datetime

text = sys.argv[1]
lines = text.split("\n")[-50:]
relevant = "\n".join(lines)

def extract(pattern):
    return list(dict.fromkeys(
        m.group(0).strip() for m in re.finditer(pattern, relevant, re.IGNORECASE)
        if len(m.group(0).strip()) > 5
    ))[:5]

adds       = extract(r'\b(add|create|implement|build|scaffold|write)\b[^.\n]{5,80}')
modifies   = extract(r'\b(update|modify|change|refactor|fix|improve)\b[^.\n]{5,80}')
removes    = extract(r'\b(remove|delete|deprecate|drop)\b[^.\n]{5,80}')
constraints= extract(r'\b(must|should|ensure|require|constraint|limit|only)\b[^.\n]{5,80}')

t3 = re.search(r'\b(auth|secret|api.key|password|token|breaking|security|new.depend)\b', relevant, re.I)
t1 = re.search(r'\b(css|typo|doc|readme|comment|format|whitespace)\b', relevant, re.I)
tier = "3" if t3 else ("1" if t1 else "2")

out = ["# UPDATE (Refined by --votu)", ""]
if adds:       out += ["## Add",        *[f"- {s}" for s in adds],        ""]
if modifies:   out += ["## Modify",     *[f"- {s}" for s in modifies],    ""]
if removes:    out += ["## Remove",     *[f"- {s}" for s in removes],     ""]
if constraints:out += ["## Constraints",*[f"- {s}" for s in constraints], ""]
out += [f"## Risk Tier: {tier}", f"_Refined: {datetime.utcnow().isoformat()}_"]

content = "\n".join(out)
with open(".ai/UPDATE.md", "w") as f:
    f.write(content)
print(content)
print("\n✓ Written to .ai/UPDATE.md")
PY
    return 0
  fi

  if [[ ! -d ".ai" ]]; then
    echo "✗ No .ai/ directory found. Run: ai init"
    exit 1
  fi
  ensure_ai_templates

  # ── Gate 1: Intent Gate ────────────────────────────────────────────────────
  if [[ $FORCE -eq 0 && -f ".ai/UPDATE.md" ]]; then
    # Check if UPDATE.md has any real content first
    RAW_CONTENT=$(grep -v '^#' .ai/UPDATE.md | grep -v '^$' \
      | grep -v '^Write a small delta' | grep -v '^Then run Claude' \
      | grep -v '^Clear this file' | grep -v '^- Add:' \
      | grep -v '^- Modify:' | grep -v '^- Remove:' \
      | grep -v '^Constraints:' || true)

    if [[ -z "$RAW_CONTENT" ]]; then
      # VOTU: If Architect is present, we don't need manual content
      echo "━━ [VOTU] VOICE OF THE USER INTAKE ━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo "   Manual UPDATE.md is empty. Architect (Gemini) will now"
      echo "   summarize chat intent and update TASKS.md automatically."
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo ""
    else
      GATE_RESULT=0
      intent_gate || GATE_RESULT=$?

      if [[ $GATE_RESULT -eq 1 ]]; then
        # Vague — hard block
        echo "Run 'ai update --force' to bypass the Intent Gate (not recommended)."
        exit 1
      fi
      # GATE_RESULT=2 (high-risk) shows warning but allows session to proceed
    fi
  fi

  # ── TSRT: Detect tier and emit tier-specific session prompt ────────────────
  local TIER=2
  if [[ -f ".ai/UPDATE.md" ]]; then
    TIER=$(detect_tier 2>/dev/null || echo "2")
  fi

  case "$TIER" in
    1)
      cat <<'TIER1'

━━ [TIER_1] LOW-RISK SESSION ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TSRT: Tier 1 detected — CSS / Docs / Typos only.
TOKEN SAVINGS: Skip Critic agents, Security review, Vibe audit, Chaos test.

PREFLIGHT:
1) Read .ai/DIGEST.md
2) Read .ai/UPDATE.md

ROLE: Principal Software Engineer (Claude).
ACTION: Apply the change, run Linter/Prettier locally.
HANDOVER: Commit with [TIER_1] tag. No agent review required.

⚠️ TOKEN RULE: Do NOT invoke security_engineer, ux_reviewer, or chaos_monkey.
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TIER1
      ;;
    3)
      cat <<'TIER3'

━━ [TIER_3] HIGH-RISK SESSION ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TSRT: Tier 3 detected — Auth / Secrets / New Features / Breaking Changes.
FULL TRIAD REQUIRED before commit.

PREFLIGHT:
1) Read .ai/DIGEST.md         ← Triad Health & Project Snapshot
2) Read .ai/architect.md      ← Principal Architect blueprint
3) Read .ai/UPDATE.md         ← human intent
4) Read .ai/TASKS.md          ← assigned tasks
5) Read .ai/CAPABILITIES.md   ← allowed scope (TIER_3 MANDATORY)

ROLE: Principal Software Engineer (Claude).
GATES REQUIRED (in order):
  1. security_engineer agent   → threat model + [SEC_CLEARED] in LOG.md
  2. blueprint-aligner-mcp     → align_diff before ANY commit
  3. ai test --vibe             → [VIBE_REPORT] + [CHAOS_CLEARED] in REVIEWS.md
  4. ai review claude           → [CRITIC_STAMP] in REVIEWS.md
HANDOVER: Mandatory [UACS_VERIFIED] stamp + Architect (Gemini) review.

⚠️ AUTHORITY: Do NOT commit until [UACS_VERIFIED] is in .ai/LOG.md.
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TIER3
      ;;
    *)
      cat <<'TIER2'

━━ [TIER_2] MEDIUM-RISK SESSION ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TSRT: Tier 2 detected — Logic / Refactor / Tests.
TOKEN SAVINGS: Skip Security review, Vibe audit, Chaos test.

PREFLIGHT:
1) Read .ai/DIGEST.md         ← Triad Health & Project Snapshot
2) Read .ai/architect.md      ← Principal Architect blueprint
3) Read .ai/UPDATE.md         ← human intent
4) Read .ai/TASKS.md          ← assigned tasks

ROLE: Principal Architect (Gemini) or Principal Software Engineer (Claude).
AUTHORITY: Unified authority over whole system. .ai/ is absolute memory.

GATES REQUIRED:
  1. Unit tests (local, 0 tokens)
  2. blueprint-aligner-mcp → align_diff (pattern consistency check)
HANDOVER: Manual Thumbs Up required. Commit with [TIER_2] tag.

⚠️ TOKEN RULE: Do NOT invoke security_engineer, ux_reviewer, or chaos_monkey.
   Do NOT read files outside your immediate domain.
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TIER2
      ;;
  esac
}

