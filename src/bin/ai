#!/usr/bin/env bash
set -euo pipefail

AIOS="${HOME}/.ai-os"
VERSION="3.2"

usage() {
  cat <<USAGE
ai — AI-OS v${VERSION}

Commands:
  ai install          Install configs to ~/.gemini + ~/.claude + ~/.config/github-copilot; enable agent teams; set up hooks
  ai init             Create/upgrade .ai/ in current repo (safe, no overwrite)
  ai onboard          Print the Principal Architect reverse-engineering prompt for existing repos
  ai update [--force] Print update session prompt (Gate 1: Intent Gate — does not scan/write itself)
  ai preflight        Print DIGEST-first read order + SESSION stamp template
  ai review <who> [--tier <1|2|3>]  Print tier-aware critic prompts (auto-detects tier)
  ai test [--vibe]    Run automated tests (TestSprite) or Vibe/Chaos audit (--vibe)
  ai mcp-setup        Install npm dependencies for all AI-OS MCP servers
  ai archive          Move old LOG/COMM/REVIEWS entries to .ai/archive/YYYY-MM/
  ai digest           Print prompt to regenerate DIGEST.md (run when stale)
  ai sync             Re-sync agents, skills, bootloaders (CLAUDE.md, GEMINI.md, .mcp.json), and hooks from ~/.ai-os
  ai sync --github    Fetch assigned GitHub issues → output to terminal for Architect cycle (§28)
  ai migrate-state [--force]  Seed state.json from TASKS.md; task-synchronizer-mcp auto-imports to state.sqlite on first run
  ai doctor [--repair] [--compliance]  Diagnose PATH, config, hooks, MCP; --compliance audits agent frontmatter for Ghost Tools
  ai where            Print install paths
  ai version          Print version
USAGE
}

# ── helpers ──────────────────────────────────────────────────────────────────

ensure_file_if_missing() {
  local src="$1" dst="$2"
  if [[ ! -f "$dst" ]]; then
    cp "$src" "$dst"
  fi
}

# Generates .mcp.json with absolute paths to ~/.ai-os/mcp/<server>/index.js
# Uses registry.json as source of truth. Preserves user-set env values.
generate_mcp_json() {
  local DEST_DIR="${1:-.}"
  local REGISTRY="${AIOS}/config/registry.json"
  local MCP_FILE="${DEST_DIR}/.mcp.json"

  if ! command -v python3 &>/dev/null; then
    [[ -f "${AIOS}/templates/.mcp.json" ]] && cp "${AIOS}/templates/.mcp.json" "$MCP_FILE"
    return
  fi

  python3 - "$REGISTRY" "$MCP_FILE" "$HOME" "$AIOS" <<'PY'
import json, sys, os
registry_path, mcp_path, home, aios = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]

servers = {
  "filesystem": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-filesystem@2026.1.14", "."],
    "description": "Scoped filesystem access — enforces CAPABILITIES.md path restrictions. Restricts to project root by default."
  },
  "memory": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-memory@2026.1.26"],
    "description": "Knowledge-graph memory store. Queryable alternative/supplement to DIGEST.md for semantic lookups."
  },
  "TestSprite": {
    "command": "npx",
    "args": ["@testsprite/testsprite-mcp@latest"],
    "env": {"API_KEY": "your-testsprite-api-key"},
    "description": "TestSprite MCP — AI-powered test generation and verification. Third brain in the Tripartite Engine (Plan->Build->Test)."
  }
}

if os.path.exists(registry_path):
    with open(registry_path) as f:
        reg = json.load(f)
    for name, info in reg.get("mcp_servers", {}).items():
        if "path" in info:
            abs_path = os.path.join(aios, "mcp", name, "index.js")
            servers[name] = {"command": "node", "args": [abs_path]}

# Preserve user-set env values from existing .mcp.json (e.g. real TestSprite API key)
if os.path.exists(mcp_path):
    try:
        with open(mcp_path) as f:
            existing = json.load(f)
        for name, cfg in existing.get("mcpServers", {}).items():
            if name in servers and "env" in cfg:
                env = cfg["env"]
                if env.get("API_KEY", "").strip() not in ("", "your-testsprite-api-key"):
                    servers[name].setdefault("env", {}).update(env)
    except Exception:
        pass

with open(mcp_path, "w") as f:
    json.dump({"mcpServers": servers}, f, indent=2)
    f.write("\n")
PY
}

# Remove frontmatter fields unsupported by Gemini CLI v0.37+
# Usage: strip_gemini_agent_fields <dir>
strip_gemini_agent_fields() {
  local dir="${1:-.gemini/agents}"
  local f
  for f in "${dir}"/*.md; do
    [[ -f "$f" ]] || continue
    # Strip disable-model-invocation, user-invocable, allowed-tools lines inside ---...--- block
    sed -i '' '/^---$/,/^---$/{
      /^disable-model-invocation:/d
      /^user-invocable:/d
      /^allowed-tools:/d
    }' "$f"
  done
}

ensure_ai_templates() {
  mkdir -p .ai .ai/archive

  local T="${AIOS}/templates"

  ensure_file_if_missing "$T/RULES.md"         ".ai/RULES.md"
  ensure_file_if_missing "$T/SEED.md"          ".ai/SEED.md"
  ensure_file_if_missing "$T/DIGEST.md"        ".ai/DIGEST.md"
  ensure_file_if_missing "$T/BRIEF.md"         ".ai/BRIEF.md"
  ensure_file_if_missing "$T/TASKS.md"         ".ai/TASKS.md"
  ensure_file_if_missing "$T/LOG.md"           ".ai/LOG.md"
  ensure_file_if_missing "$T/architect.md.template" ".ai/architect.md"
  ensure_file_if_missing "$T/state.json"          ".ai/state.json"

  # .gitignore for sensitive .ai/ files
  if [[ ! -f ".ai/.gitignore" ]]; then
    cp "$T/_gitignore" ".ai/.gitignore"
    echo "Created .ai/.gitignore (review it — sensitive files excluded from git)"
  fi

  # .mcp.json — always regenerate to pick up new servers (preserves user env values)
  generate_mcp_json "."
  echo "Updated .mcp.json (MCP servers: filesystem + memory + AI-OS custom servers)"

  # CLAUDE.md — always update bootloader so skill invocation stays current
  cp -f "$T/CLAUDE.md" "CLAUDE.md"
  echo "Updated CLAUDE.md (project bootloader)"

  # GEMINI.md — always update bootloader
  cp -f "$T/GEMINI.md" "GEMINI.md"
  echo "Updated GEMINI.md (project bootloader)"

  # .claude/ — project-scoped Claude agents, skills, and settings
  mkdir -p ".claude/agents" ".claude/skills" ".claude/commands"
  cp -rf "${AIOS}/claude/agents/"*.md ".claude/agents/" 2>/dev/null || true
  sync_skills_20 "${AIOS}/shared/skills" ".claude/skills"
  sync_skills_20 "${AIOS}/claude/skills" ".claude/skills"
  _configure_project_claude_settings ".claude"
  echo "Created .claude/ (project-scoped agents + skills + settings.json)"

  # .gemini/ — project-scoped Gemini agents, skills, and settings
  mkdir -p ".gemini/agents" ".gemini/skills"
  cp -rf "${AIOS}/gemini/agents/"*.md ".gemini/agents/" 2>/dev/null || true
  strip_gemini_agent_fields ".gemini/agents"
  sync_skills_20 "${AIOS}/shared/skills" ".gemini/skills"
  sync_skills_20 "${AIOS}/gemini/skills" ".gemini/skills"
  _configure_project_gemini_settings ".gemini"
  echo "Created .gemini/ (project-scoped agents + skills + settings.json)"

  # .github/copilot-instructions.md — read automatically by GitHub Copilot Chat
  local C="${AIOS}/copilot"
  if [[ -f "${C}/copilot-instructions.md" && ! -f ".github/copilot-instructions.md" ]]; then
    mkdir -p .github
    cp "${C}/copilot-instructions.md" ".github/copilot-instructions.md"
    echo "Created .github/copilot-instructions.md (fill in project-specific Copilot context)"
  fi
}

migrate_legacy_ai_if_present() {
  local legacy=0
  for f in MASTER.md HANDOFF.md OWNERSHIP.md RUNBOOK.md 00_context.md 01_repo_state.md 05_input.md 50_acceptance.md 40_implementation_log.md; do
    [[ -f ".ai/$f" ]] && legacy=1 && break
  done
  if [[ $legacy -eq 1 ]]; then
    mkdir -p .ai/legacy
    for f in MASTER.md HANDOFF.md OWNERSHIP.md RUNBOOK.md 00_context.md 01_repo_state.md 05_input.md 50_acceptance.md 40_implementation_log.md; do
      [[ -f ".ai/$f" ]] && mv ".ai/$f" ".ai/legacy/$f"
    done
    { echo ""; echo "## Legacy migration ($(date '+%Y-%m-%d'))"; echo "- Moved legacy .ai files to .ai/legacy/"; echo "- Review and copy relevant content into BRIEF/TASKS/REPO."; } >> .ai/MIGRATION.md
    echo "Legacy .ai files moved to .ai/legacy/ — review MIGRATION.md"
  fi
}


# Writes .claude/settings.json in a project directory with project-scoped hooks,
# agent teams env var, Gemini permission, and registry-driven MCP tool permissions.
# $1: target dir (e.g. ".claude")
_configure_project_claude_settings() {
  local TARGET_DIR="${1:-.claude}"
  local REGISTRY="${AIOS}/config/registry.json"
  mkdir -p "$TARGET_DIR"
  python3 - "$TARGET_DIR" "$REGISTRY" <<'PY'
import json, os, sys

target_dir = sys.argv[1]
registry_path = sys.argv[2]
path = os.path.join(target_dir, "settings.json")

data = {}
if os.path.exists(path):
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f) or {}
    except Exception:
        pass

# Enable agent teams
env = data.setdefault("env", {})
env["CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS"] = "1"

# Permissions: scoped Gemini CLI + registry-driven MCP tools
perms = data.setdefault("permissions", {})
allow = perms.get("allow", [])
new_allow = []
for entry in allow:
    if entry == "Bash(gemini *)":
        new_allow.append("Bash(gemini -p *)")
        print("Tightened: Bash(gemini *) → Bash(gemini -p *)")
    else:
        new_allow.append(entry)
if "Bash(gemini -p *)" not in new_allow and "Bash(gemini *)" not in new_allow:
    new_allow.append("Bash(gemini -p *)")
    print("Added: Bash(gemini -p *)")
if os.path.exists(registry_path):
    with open(registry_path) as rf:
        reg = json.load(rf)
    for srv, info in reg.get("mcp_servers", {}).items():
        if "path" not in info:
            continue
        for tool in info.get("allowed-tools", []):
            if tool == "*":
                continue
            perm = f"mcp__{srv}__{tool}"
            if perm not in new_allow:
                new_allow.append(perm)
                print(f"Added MCP permission: {perm}")
perms["allow"] = new_allow

# Hooks
hooks = data.setdefault("hooks", {})

stop_cmd = "bash $HOME/.ai-os/hooks/stop-hook.sh"
stop_hooks = hooks.setdefault("Stop", [])
already = any(
    h.get("command") == stop_cmd
    for entry in stop_hooks
    for h in entry.get("hooks", [])
)
if not already:
    stop_hooks.append({"matcher": ".*", "hooks": [{"type": "command", "command": stop_cmd}]})

post_cmd = "bash $HOME/.ai-os/hooks/post-tool-log.sh"
post_hooks = hooks.setdefault("PostToolUse", [])
already = any(
    h.get("command") == post_cmd
    for entry in post_hooks
    for h in entry.get("hooks", [])
)
if not already:
    post_hooks.append({"matcher": "Write|Edit", "hooks": [{"type": "command", "command": post_cmd}]})

agq_cmd = "bash $HOME/.ai-os/hooks/post-tool-use.sh"
already_agq = any(
    h.get("command") == agq_cmd
    for entry in post_hooks
    for h in entry.get("hooks", [])
)
if not already_agq:
    post_hooks.append({"matcher": "Write|Edit", "hooks": [{"type": "command", "command": agq_cmd}]})

with open(path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write("\n")
print(f"{path} updated ✓")
PY
}

# Writes .gemini/settings.json in a project directory with project-scoped MCP server config.
# $1: target dir (e.g. ".gemini")
_configure_project_gemini_settings() {
  local TARGET_DIR="${1:-.gemini}"
  local REGISTRY="${AIOS}/config/registry.json"
  mkdir -p "$TARGET_DIR"
  python3 - "$TARGET_DIR" "$REGISTRY" "$AIOS" <<'PY'
import json, os, sys

target_dir, registry_path, aios = sys.argv[1], sys.argv[2], sys.argv[3]
path = os.path.join(target_dir, "settings.json")

# Base npm-managed servers (not path-based, shared between Claude and Gemini)
servers = {
    "filesystem": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem@2026.1.14", os.getcwd()]
    },
    "memory": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-memory@2026.1.26"]
    }
}

# Registry-driven custom servers (same source of truth as generate_mcp_json)
if os.path.exists(registry_path):
    with open(registry_path) as f:
        reg = json.load(f)
    for name, info in reg.get("mcp_servers", {}).items():
        if "path" in info:
            abs_path = os.path.join(aios, "mcp", name, "index.js")
            servers[name] = {"command": "node", "args": [abs_path]}

data = {}
if os.path.exists(path):
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f) or {}
    except Exception as e:
        print(f"WARN: {path} is not valid JSON ({e}). Recreating.")

data["mcpServers"] = servers

with open(path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write("\n")
print(f"{path} MCP config updated ✓")
PY
}

install_global() {
  echo "Preparing AI-OS v2 installation..."

  # Copilot CLI
  mkdir -p "${HOME}/.config/github-copilot"
  if [[ -f "${AIOS}/copilot/COPILOT.md" ]]; then
    cp -f "${AIOS}/copilot/COPILOT.md" "${HOME}/.config/github-copilot/COPILOT.md"
  fi
  echo "✓ Installed Copilot config → ~/.config/github-copilot"

  if command -v gh &>/dev/null && gh extension list 2>/dev/null | grep -q "github/gh-copilot"; then
    gh copilot config set telemetry false 2>/dev/null || true
    echo "  gh copilot: configured ✓ (telemetry off)"
  else
    echo "  gh copilot: not installed — Recommended: gh extension install github/gh-copilot"
  fi

  # Hooks
  chmod +x "${AIOS}/hooks/"*.sh 2>/dev/null || true
  echo "✓ Hooks ready → ${AIOS}/hooks"

  # MCP servers
  if [[ -d "${AIOS}/mcp" ]]; then
    echo "✓ MCP servers available → ${AIOS}/mcp"
  fi

  # Install MCP server npm dependencies
  if command -v node &>/dev/null; then
    echo "Setting up MCP server dependencies..."
    do_mcp_setup 2>/dev/null || echo "  ⚠  MCP setup: some servers failed — run: ai mcp-setup"
  else
    echo "  ⚠  Node.js not found — MCP setup skipped. Install Node.js then run: ai mcp-setup"
  fi

  # Strip unsupported Gemini CLI frontmatter fields from global agent sources
  if [[ -d "${AIOS}/gemini/agents" ]]; then
    strip_gemini_agent_fields "${AIOS}/gemini/agents"
    echo "✓ Gemini agent frontmatter sanitized (stripped unsupported fields)"
  fi

  echo ""
  echo "✓ AI-OS global installation complete → ${AIOS}"
  echo "  Run 'ai init' inside any project to scaffold .ai/, .claude/, and .gemini/."
}

install_git_hooks() {
  local GIT_HOOKS_DIR
  GIT_HOOKS_DIR="$(git rev-parse --git-dir 2>/dev/null)/hooks"
  if [[ -z "$GIT_HOOKS_DIR" || ! -d "$GIT_HOOKS_DIR" ]]; then
    echo "  ⚠  Not a git repo — skipping git hook install"
    return
  fi

  local HOOK_SRC="${AIOS}/hooks/pre-commit.sh"
  local HOOK_DST="${GIT_HOOKS_DIR}/pre-commit"

  if [[ ! -f "$HOOK_SRC" ]]; then
    echo "  ⚠  pre-commit.sh not found at ${HOOK_SRC} — run: ai install"
    return
  fi

  if [[ -f "$HOOK_DST" ]]; then
    # Check if it's already the AI-OS hook
    if grep -q "AI-OS Gate 2" "$HOOK_DST" 2>/dev/null; then
      echo "  ✓ pre-commit hook already installed (Gate 2)"
      return
    else
      # Preserve existing hook — chain it
      local BACKUP="${HOOK_DST}.pre-aios"
      mv "$HOOK_DST" "$BACKUP"
      echo "  ✓ Backed up existing pre-commit hook → pre-commit.pre-aios"
      # Write wrapper that calls both
      cat > "$HOOK_DST" <<WRAPPER
#!/usr/bin/env bash
# AI-OS pre-commit wrapper — calls original hook then AI-OS Gate 2
bash "\$(dirname "\$0")/pre-commit.pre-aios" || exit 1
bash "${HOOK_SRC}" || exit 1
WRAPPER
    fi
  else
    cp "$HOOK_SRC" "$HOOK_DST"
  fi

  chmod +x "$HOOK_DST"
  echo "  ✓ Installed Gate 2 (Quality Gate) pre-commit hook → ${HOOK_DST}"

  # E-55: Install post-commit hook (TASKS.md auto-sync)
  local PC_SRC="${AIOS}/hooks/post-commit.sh"
  local PC_DST="${GIT_HOOKS_DIR}/post-commit"

  if [[ ! -f "$PC_SRC" ]]; then
    echo "  ⚠  post-commit.sh not found at ${PC_SRC} — run: ai install"
    return
  fi

  if [[ -f "$PC_DST" ]]; then
    if grep -q "AI-OS.*TASK-SYNC\|TASKS.md Auto-Sync" "$PC_DST" 2>/dev/null; then
      echo "  ✓ post-commit hook already installed (TASK-SYNC)"
      return
    else
      # Chain with existing hook
      local PC_BACKUP="${PC_DST}.pre-aios"
      mv "$PC_DST" "$PC_BACKUP"
      echo "  ✓ Backed up existing post-commit hook → post-commit.pre-aios"
      cat > "$PC_DST" <<WRAPPER
#!/usr/bin/env bash
# AI-OS post-commit wrapper — calls original hook then AI-OS TASK-SYNC
bash "\$(dirname "\$0")/post-commit.pre-aios" || true
bash "${PC_SRC}" || true
WRAPPER
    fi
  else
    cp "$PC_SRC" "$PC_DST"
  fi

  chmod +x "$PC_DST"
  echo "  ✓ Installed TASK-SYNC post-commit hook → ${PC_DST}"
}

# E-114: Query global memory store for similar projects during ai init (§31 advisory hint)
# Silent failure — project-local context always takes priority.
_query_similar_signatures() {
  local MEM_DIR="${AIOS}/memory"
  local SIG_FILE="${MEM_DIR}/signatures.json"
  if ! command -v python3 &>/dev/null; then return 0; fi
  if [[ ! -f "$SIG_FILE" ]]; then return 0; fi
  local PROJECT_TAG
  PROJECT_TAG="$(basename "$(pwd)")"

  python3 - "$SIG_FILE" "$PROJECT_TAG" <<'PY' 2>/dev/null || true
import json, sys
sig_file  = sys.argv[1]
query_tag = sys.argv[2].lower()

try:
    sigs = json.load(open(sig_file))
    if not isinstance(sigs, list) or not sigs:
        sys.exit(0)
    matched = [
        s for s in sigs
        if query_tag in str(s.get("project_name", "")).lower()
        or query_tag in str(s.get("tag", "")).lower()
        or any(query_tag in str(t).lower() for t in (s.get("tags") or []))
    ]
    if not matched:
        sys.exit(0)
    print("\nSimilar projects from memory palace (advisory):")
    for s in matched[:3]:
        print(f"  • {s.get('project_name','?')}: {str(s.get('summary',''))[:100]}")
except Exception:
    pass  # Silent failure per §31
PY
}

do_init() {
  ensure_ai_templates
  migrate_legacy_ai_if_present
  install_git_hooks

  # E-33: Auto-setup MCP server dependencies (Battery-Included onboarding)
  if command -v node &>/dev/null && [[ -d "${AIOS}/mcp" ]]; then
    echo ""
    echo "Setting up MCP servers (Node.js detected)..."
    do_mcp_setup 2>/dev/null || echo "  ⚠  MCP setup incomplete — run: ai mcp-setup"
  else
    echo ""
    echo "MCP servers: Node.js not found — run 'ai mcp-setup' after installing Node.js"
  fi

  # E-93: Structured-First init — seed state.json from TASKS.md automatically
  if [[ -f ".ai/TASKS.md" ]]; then
    echo ""
    echo "Seeding state.json from TASKS.md (Structured-First init)..."
    do_migrate_state --force 2>/dev/null || echo "  ⚠  State migration incomplete — run: ai migrate-state --force"
  fi

  # E-114: Query global memory store for similar architectural patterns (§31 advisory)
  _query_similar_signatures 2>/dev/null || true

  echo ""
  echo "Initialized .ai/ + .github/ (safe — no overwrites) with AI-OS v${VERSION}"
  echo ""
  echo "Next (MANDATORY):"
  echo "1) Fill in .ai/BRIEF.md and .ai/REPO.md"
  echo "2) Fill in .ai/DIGEST.md — Include Triad Health (Planning/Execution/Testing)"
  echo "3) Define the initial vision in .ai/architect.md (Template provided)"
  echo "4) Fill in .github/copilot-instructions.md (project-specific context)"
  echo "5) ai update     — start a peer agent session"
  echo ""
  echo "Triad Workflow:"
  echo "  Architect (Gemini) → Writes to architect.md / Planning docs"
  echo "  Engineer (Claude)  → Implements code based on blueprints"
  echo "  Tester (TestSprite) → Mandatory quality gate via 'ai test'"
  echo ""
  echo "MCP servers enabled in .mcp.json (filesystem + memory)."
}

# ── TSRT: Tier classifier (bash-native, no MCP dependency) ──────────────────
# Reads staged diff, returns 1/2/3 via stdout.
# Used by do_update, do_review, and the pre-commit hook for gate skipping.
#
# Tier 1 — Docs/config only (no logic files):
#   *.md, *.txt, .gitignore, .ai/**, .claude/**, .gemini/**, *.json (non-src)
# Tier 2 — Logic change (src/, *.js, *.ts, *.py, *.sh, hooks, mcp):
#   any file matching LOGIC_RE
# Tier 3 — High-risk (auth, secrets, deploy, breaking, CI):
#   any staged file content matching HIGH_RISK_RE
detect_tier() {
  local staged_files
  staged_files=$(git diff --staged --name-only 2>/dev/null)

  # No staged files → default Tier 2 (conservative)
  [[ -z "$staged_files" ]] && echo "2" && return

  # Tier 3: high-risk keywords in diff content
  local HIGH_RISK_RE='\b(auth|oauth|secret|api[_-]?key|deploy|production|migration|breaking|password|token)\b'
  if git diff --staged 2>/dev/null | grep -qiE "$HIGH_RISK_RE"; then
    echo "3" && return
  fi

  # Tier 2: any logic file in staged list
  local LOGIC_RE='\.(js|ts|mjs|cjs|jsx|tsx|py|go|rb|java|sh|bash|zsh)$|^src/|^mcp/|hooks/'
  while IFS= read -r file; do
    if [[ "$file" =~ $LOGIC_RE ]]; then
      echo "2" && return
    fi
  done <<< "$staged_files"

  # All files are docs/config → Tier 1
  echo "1"
}

# ── Gate 1: Intent Gate ───────────────────────────────────────────────────────
# Returns: 0 = pass, 1 = vague (hard block), 2 = high-risk (soft block / warning)

do_update() {
  if [[ ! -d ".ai" ]]; then
    echo "✗ No .ai/ directory found. Run: ai init"
    exit 1
  fi

  # Capture inline intent from CLI args (e.g., ai update "add feature X")
  local INTENT="${*:-}"
  local INTENT_BLOCK=""
  if [[ -n "$INTENT" && "$INTENT" != "--force" ]]; then
    INTENT_BLOCK="
INTENT FROM CLI:
  ${INTENT}
"
  fi

  cat <<PROMPT
━━ AI-OS UPDATE SESSION ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
${INTENT_BLOCK}
ROLE: Principal Architect (Gemini) or Principal Software Engineer (Claude).

TOKEN ECONOMICS — HARD LIMIT: Read at most 6 files. No ls -R, no glob sweeps.

STEP 1 — REFRESH PROJECT STATE (JIT)
Run the digest_updater agent to refresh .ai/DIGEST.md:
  activate_agent('digest_updater')
The agent uses git-based change detection — only reads files changed since
last DIGEST update. If nothing changed, it exits early (no token burn).

STEP 2 — READ CONTEXT (max 3 files)
  a. .ai/DIGEST.md    ← refreshed project snapshot
  b. .ai/TASKS.md     ← open E-## / P-## tasks
  c. .ai/architect.md ← ONLY if intent requires architectural context

STEP 3 — PROCESS INTENT
Intent comes from the conversation message above${INTENT_BLOCK:+ (or CLI arg above)}.
Do NOT look for an UPDATE.md file — it no longer exists.

STEP 4 — UPDATE STATE
Based on the intent and refreshed DIGEST:
  • New tasks: mcp__task-synchronizer-mcp__add_task({ prefix, description, tier })
  • DIGEST is already updated by Step 1 — do not rewrite it manually.
  • Log changes: append to .ai/LOG.md.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PROMPT
}

do_onboard() {
  cat <<'ONBD'

━━ ONBOARDING SYSTEM OVERRIDE (For Existing Codebases) ━━━━━━━━━━━━━━
Paste this prompt into Claude or Gemini:

"You are the Principal Architect.
I have just initialized AI-OS v2 in this existing codebase.
Your task is to reverse-engineer this repository and establish the Triad.

TOKEN ECONOMICS — HARD LIMIT: Read at most 6 files total. Do NOT run ls -R,
find ., or read every source file. Use targeted reads only.

1. Read README.md and package.json (or equivalent manifest) — 2 files max.
2. Read the entry point (e.g. src/index.*, src/bin/*) — 1 file.
3. Grep for key patterns (imports, exports, routes) rather than reading whole dirs.
4. Populate `.ai/DIGEST.md` with the snapshot (max 50 lines).
5. Populate `.ai/BRIEF.md` with the system architecture summary.
6. Draft the first `.ai/architect.md` blueprint.

Do NOT write any application code. Output only `.ai/` documentation."
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ONBD
}

preflight() {
  if [[ ! -f ".ai/SEED.md" ]]; then
    echo "Missing .ai/SEED.md — run: ai init"
    exit 1
  fi
  cat <<'PREF'

━━ PREFLIGHT READ ORDER (DIGEST-FIRST) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Always read:
  1. .ai/DIGEST.md        ← replaces most reads if current
  2. .ai/TASKS.md         ← your assigned tasks
  3. .ai/architect.md     ← Blueprint (only if task requires architectural detail)

The absolute source of truth is .ai/.
Handover protocol (Engineer): Always record execution state back to LOG.md.
Open only when task touches that domain:
  • .ai/BRIEF.md (Project Rules & Lore)
  • .ai/RULES.md (Token Economics & Triad Contract)

SESSION.md is auto-stamped by Stop hook after your session ends.
Manual stamp only if hook fails.
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

PREF
}



do_digest() {
  cat <<'DGT'

━━ REGENERATE DIGEST PROMPT ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Paste into Claude Code:

"Use the digest_updater agent to regenerate .ai/DIGEST.md.
 TOKEN ECONOMICS: Use JIT reads — grep first, full reads only for changed files.
 Step 1: git log --since=<DIGEST mtime> --name-only -- '.ai/*.md' | sort -u
 Step 2: Read ONLY files listed above. Max 6 files total.
 Keep DIGEST ≤ 60 lines, bullets only. Include Recent changes (last 10)."
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DGT
}

do_archive() {
  if [[ ! -d ".ai" ]]; then
    echo "✗ No .ai/ directory found. Run: ai init"
    exit 1
  fi

  local ARCHIVE_DIR
  ARCHIVE_DIR=".ai/archive/$(date '+%Y-%m')"
  mkdir -p "$ARCHIVE_DIR"

  local SUFFIX
  SUFFIX=$(date '+%Y%m%d_%H%M')

  local ARCHIVED=0

  # Files to archive (content files that accumulate over time)
  for fname in LOG.md COMM.md REVIEWS.md SESSION.md; do
    local src=".ai/${fname}"
    [[ ! -f "$src" ]] && continue

    # Only archive if non-empty (beyond header line)
    local content
    content=$(grep -v '^#' "$src" | grep -v '^$' | head -5 || true)
    if [[ -z "$content" ]]; then
      echo "  Skipped ${fname} (empty)"
      continue
    fi

    local dst="${ARCHIVE_DIR}/${fname%.md}.${SUFFIX}.md"
    mv "$src" "$dst"
    echo "  Archived: ${fname} → ${dst}"
    ARCHIVED=$((ARCHIVED + 1))

    # Re-initialize from template or with header
    local T="${AIOS}/templates"
    if [[ -f "${T}/${fname}" ]]; then
      cp "${T}/${fname}" "$src"
    else
      printf "# %s\n\n" "$fname" > "$src"
    fi
    echo "  Re-initialized: ${fname}"
  done

  if [[ $ARCHIVED -eq 0 ]]; then
    echo "Nothing to archive — all content files are empty."
  else
    echo ""
    echo "✓ Archive complete → ${ARCHIVE_DIR}"
    echo "  ${ARCHIVED} file(s) archived and re-initialized."
    echo ""
    # E-107: Export project signature to global memory store (§31, silent failure by design)
    _export_signature_to_global_store
    # E-56: Auto-trigger digest to document the fresh state
    echo "[AUTO-ARCHIVE] Regenerating DIGEST.md to reflect fresh state..."
    do_digest
  fi
}

# E-107: Write project signature to ~/.ai-os/memory/signatures.json (§31)
# Silent failure — project-local context is always prioritized.
_export_signature_to_global_store() {
  local MEM_DIR="${AIOS}/memory"
  local SIG_FILE="${MEM_DIR}/signatures.json"
  if ! command -v python3 &>/dev/null; then return 0; fi

  # P-45: Extract focus from state.sqlite (SQLite-first); fall back to state.json in Python
  local _FOCUS=""
  if [[ -f ".ai/state.sqlite" ]] && command -v sqlite3 &>/dev/null; then
    _FOCUS=$(sqlite3 ".ai/state.sqlite" "SELECT value FROM project WHERE key='focus'" 2>/dev/null || true)
  fi

  python3 - "$SIG_FILE" "$MEM_DIR" "$_FOCUS" <<'PY'
import json, sys, os
from datetime import datetime, timezone

sig_file = sys.argv[1]
mem_dir  = sys.argv[2]

try:
    os.makedirs(mem_dir, exist_ok=True)

    # Build signature from available .ai/ context
    project_name = os.path.basename(os.getcwd())

    # Extract focus — prefer pre-computed SQLite value, fall back to state.json
    focus = sys.argv[3] if len(sys.argv) > 3 and sys.argv[3] else ""
    if not focus:
        try:
            s = json.load(open(".ai/state.json"))
            focus = s.get("project", {}).get("focus") or ""
        except Exception:
            pass

    # Extract summary from DIGEST.md (first 5 non-header, non-empty lines)
    summary_lines = []
    try:
        for line in open(".ai/DIGEST.md"):
            stripped = line.strip()
            if stripped and not stripped.startswith("#") and len(summary_lines) < 5:
                summary_lines.append(stripped)
    except Exception:
        pass
    summary = " | ".join(summary_lines) if summary_lines else f"{project_name} project"

    # Extract architect version (first # heading from architect.md)
    architect_v = "unknown"
    try:
        for line in open(".ai/architect.md"):
            if line.startswith("# "):
                architect_v = line.strip()[2:].strip()
                break
    except Exception:
        pass

    sig = {
        "project_name": project_name,
        "tag": focus or project_name,
        "summary": summary[:300],   # cap at 300 chars — no PII, no secrets
        "architect_v": architect_v[:100],
        "timestamp": datetime.now(timezone.utc).isoformat()
    }

    # Append to global signatures store
    sigs = []
    if os.path.exists(sig_file):
        try:
            sigs = json.load(open(sig_file))
            if not isinstance(sigs, list):
                sigs = []
        except Exception:
            sigs = []

    # Deduplicate: remove older entry for same project (keep latest only)
    sigs = [s for s in sigs if s.get("project_name") != project_name]
    sigs.append(sig)

    with open(sig_file, "w") as f:
        json.dump(sigs, f, indent=2)
        f.write("\n")

    print(f"[SIGNATURE] Exported {project_name} signature → {sig_file}")
except Exception as e:
    # Silent failure per §31 — global store is optional
    pass
PY
}

do_migrate_state() {
  local FORCE="${1:-}"

  if [[ ! -d ".ai" ]]; then
    echo "✗ No .ai/ directory found. Run: ai init"
    exit 1
  fi

  local STATE_FILE=".ai/state.json"
  local TASKS_FILE=".ai/TASKS.md"

  if [[ ! -f "$TASKS_FILE" ]]; then
    echo "✗ .ai/TASKS.md not found — nothing to migrate."
    exit 1
  fi

  if ! command -v python3 &>/dev/null; then
    echo "✗ python3 required for migration"
    exit 1
  fi

  if ! command -v node &>/dev/null; then
    echo "✗ node required for migration"
    exit 1
  fi

  # Guard: if state.json already has tasks, require --force
  if [[ -f "$STATE_FILE" ]]; then
    local task_count
    task_count=$(python3 -c "
import json, sys
try:
    d = json.load(open('${STATE_FILE}'))
    print(len(d.get('tasks', [])))
except:
    print(0)
" 2>/dev/null || echo "0")
    if [[ "$task_count" -gt 0 && "$FORCE" != "--force" ]]; then
      echo "[MIGRATE-STATE] state.json already has ${task_count} tasks. Use --force to re-migrate."
      exit 1
    fi
  fi

  echo "[MIGRATE-STATE] Parsing .ai/TASKS.md..."

  local PARSED_TMPFILE
  PARSED_TMPFILE=$(mktemp /tmp/ai_migrate_XXXXXX.json)

  python3 - "$TASKS_FILE" "$PARSED_TMPFILE" <<'PY'
import json, re, sys

tasks_file = sys.argv[1]
out_file   = sys.argv[2]

tasks = []

SECTION_RE = re.compile(r'^#{1,3}\s+(.+)$')
TASK_RE    = re.compile(r'^- \[([ x])\] (E|P|T)-(\d+):?\s+(.+?)(?:\s*\|\s*Tier:\s*(\d))?$')
STATUS_RE  = re.compile(r'^\s{2}Status:\s+DONE\s+(\d{4}-\d{2}-\d{2})\s+[—–-]\s+(.+)$')

OWNER_PATTERNS = [
    (re.compile(r'\bArchitect\b|\(Gemini\)',     re.IGNORECASE), 'Architect (Gemini)'),
    (re.compile(r'\bEngineer\b|\(Claude\)',      re.IGNORECASE), 'Engineer (Claude)'),
    (re.compile(r'\bTester\b|\(TestSprite\)',    re.IGNORECASE), 'Tester (TestSprite)'),
]

current_owner = None
last_task     = None

with open(tasks_file, encoding='utf-8') as f:
    lines = f.readlines()

for line in lines:
    line_s = line.rstrip('\n')

    # Section header — update owner if recognisable
    m = SECTION_RE.match(line_s)
    if m:
        header = m.group(1).strip()
        for pattern, owner in OWNER_PATTERNS:
            if pattern.search(header):
                current_owner = owner
                break
        last_task = None
        continue

    # Task line
    m = TASK_RE.match(line_s)
    if m:
        status_char, prefix, num, desc, tier = m.groups()
        task = {
            'id':           f'{prefix}-{int(num)}',
            'owner':        current_owner or 'Unassigned',
            'status':       'DONE' if status_char == 'x' else 'OPEN',
            'tier':         int(tier) if tier else None,
            'description':  desc.strip(),
            'created_at':   None,
            'completed_at': None,
            'summary':      None,
        }
        tasks.append(task)
        last_task = task
        continue

    # Status line (must immediately follow a task line)
    if last_task:
        m = STATUS_RE.match(line_s)
        if m:
            date_str, summary = m.groups()
            last_task['completed_at'] = date_str + 'T00:00:00.000Z'
            last_task['summary']      = summary.strip()
        elif line_s.strip() and not line_s.startswith(' '):
            last_task = None

with open(out_file, 'w', encoding='utf-8') as f:
    json.dump(tasks, f, indent=2)

print(f'[MIGRATE-STATE] Parsed {len(tasks)} tasks from TASKS.md.')
PY

  local TASK_COUNT
  TASK_COUNT=$(python3 -c "import json; print(len(json.load(open('${PARSED_TMPFILE}'))))" 2>/dev/null || echo "0")

  if [[ "$TASK_COUNT" -eq 0 ]]; then
    echo "[MIGRATE-STATE] Warning: 0 tasks parsed. Check TASKS.md format."
    rm -f "$PARSED_TMPFILE"
    exit 0
  fi

  echo "[MIGRATE-STATE] Writing ${TASK_COUNT} tasks to ${STATE_FILE}..."

  node -e "
    const fs = require('fs');
    const statePath  = process.argv[1];
    const parsedPath = process.argv[2];
    const parsedTasks = JSON.parse(fs.readFileSync(parsedPath, 'utf8'));

    let state;
    try {
      state = JSON.parse(fs.readFileSync(statePath, 'utf8'));
    } catch {
      state = { version: '1.0', project: { current_tier: null, release_verdict: null, focus: null }, tasks: [], stamps: [] };
    }

    const now = new Date().toISOString();
    for (const t of parsedTasks) {
      if (!t.created_at) t.created_at = t.completed_at || now;
    }

    state.tasks = parsedTasks;
    fs.writeFileSync(statePath, JSON.stringify(state, null, 2) + '\n', 'utf8');
    console.log('[MIGRATE-STATE] state.json updated: ' + parsedTasks.length + ' tasks written.');
  " "$STATE_FILE" "$PARSED_TMPFILE"

  rm -f "$PARSED_TMPFILE"

  echo ""
  echo "[MIGRATE-STATE] Migration complete."
  printf "  Tasks seeded to state.json: %s\n" "$TASK_COUNT"
  echo "  state.sqlite: will be created from state.json on first task-synchronizer-mcp call"
  echo "  Run: ai test to verify"
}

do_review() {
  local who="${1:-}"
  if [[ -z "$who" ]]; then
    echo "Usage: ai review <claude|gemini> [--tier <1|2|3>]"
    exit 1
  fi

  # Parse --tier flag (overrides auto-detection)
  local TIER_OVERRIDE=""
  local i=2
  while [[ $i -le $# ]]; do
    local arg="${!i}"
    if [[ "$arg" == "--tier" ]]; then
      i=$((i+1)); TIER_OVERRIDE="${!i}"
    fi
    i=$((i+1))
  done

  # Auto-detect tier from staged diff unless overridden
  local TIER="${TIER_OVERRIDE}"
  local TIER_SOURCE=""
  if [[ -n "$TIER_OVERRIDE" ]]; then
    TIER_SOURCE="manual --tier override"
  elif [[ -d ".ai" ]]; then
    TIER=$(detect_tier 2>/dev/null || echo "2")
    case "$TIER" in
      1) TIER_SOURCE="auto-detected: docs/config only (no logic files staged)" ;;
      3) TIER_SOURCE="auto-detected: high-risk keywords found in staged diff" ;;
      *) TIER_SOURCE="auto-detected: logic files staged (src/, *.js/ts/py/sh)" ;;
    esac
  else
    TIER="2"
    TIER_SOURCE="default (not in AI-OS project)"
  fi
  TIER="${TIER:-2}"

  echo ""
  echo "TSRT: Tier ${TIER} [${TIER_SOURCE}]"
  echo ""

  case "$who" in
    claude)
      # Tier 1 — skip review entirely
      if [[ "$TIER" == "1" ]]; then
        cat <<'TIER1_REVIEW'

━━ [TIER_1] REVIEW SKIPPED (TSRT) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Tier 1 — docs/config only. Gate 2 will bypass automatically.
No [CRITIC_STAMP] required.

ACTION: Commit directly — the pre-commit hook will print:
  [TIER_1] Docs/config only — Gate 2 bypassed
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TIER1_REVIEW
        return
      fi

      # Tier 2 — blueprint_aligner only (skip security/vibe/chaos)
      if [[ "$TIER" == "2" ]]; then
        cat <<'TIER2_REVIEW'

━━ [TIER_2] REVIEW PROMPT — Claude (Blueprint Aligner) ━━━━━━━━━━━━━
TSRT: Tier 2 — skipping Security, Vibe, and Chaos agents (token savings).
Paste this into Claude Code:

"You are the Principal Software Engineer running a Tier 2 review.
Run blueprint-aligner-mcp to verify pattern consistency:

1. Call blueprint-aligner-mcp → align_diff
   → Confirm all changes follow existing patterns in architect.md
   → Flag any [WARN] or [FAIL] deviations

2. Run unit tests: npm test (or equivalent for this project)

3. Record stamp via MCP — do NOT write directly to .ai/REVIEWS.md:
   mcp__task-synchronizer-mcp__add_stamp({
     type: 'CRITIC_STAMP',
     agent: 'blueprint-aligner-mcp',
     summary: '[TIER_2] <one-line summary>'
   })
   This persists to state.sqlite so the stamp survives regenerateViews().

Commit after stamp is written: git commit -m \"[TIER_2] <description>\""
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TIER2_REVIEW
        return
      fi

      # Tier 3 — full Triad (default for high-risk or explicit --tier 3)
      cat <<'TIER3_REVIEW'

━━ [TIER_3] REVIEW PROMPT — Claude (Full Triad) ━━━━━━━━━━━━━━━━━━━━
TSRT: Tier 3 — High Risk. Full Triad required before commit.
Paste this into Claude Code:

"You are the Principal Software Engineer running a Tier 3 full review.
Execute ALL of the following IN PARALLEL where possible:

1. security_engineer agent
   → Threat model the changes. Verify no credential exposure.
   → Append [SEC_CLEARED] YYYY-MM-DD to .ai/LOG.md if clear.

2. critic_arch (sub-agent)
   → Review src/ against .ai/architect.md. Flag sovereignty violations.

3. critic_security (sub-agent)
   → OWASP Top 10, shell injection, env variable leakage, CAPABILITIES.md.

4. critic_tests (sub-agent)
   → Coverage gaps, untested edge cases, quality gate holes.

5. blueprint-aligner-mcp → align_diff
   → Verify git diff aligns with blueprint. Return [PASS/FAIL].

After ALL complete:
  → Invoke review_synthesizer agent — it reads all distributed stamps
    and writes the final CRITIC_STAMP via MCP (persists to state.sqlite):
    activate_agent('review_synthesizer')
  → Do NOT write [CRITIC_STAMP] directly to .ai/REVIEWS.md — use MCP only.
  → If all clear: append [UACS_VERIFIED] YYYY-MM-DD to .ai/LOG.md
  → Then run: ai test --vibe (required for Tier 3 release)

Do NOT commit until [UACS_VERIFIED] is in .ai/LOG.md."
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TIER3_REVIEW
      ;;
    gemini)
      cat <<'GEMINI_PROMPT'

━━ REVIEW PROMPT — Gemini (Architectural Audit) ━━━━━━━━━━━━━━━━━━━━
Paste this into Gemini (or gemini -p):

"You are the Principal Architect performing an architectural audit.

1. Read .ai/architect.md (your blueprint — the source of truth).
2. Read .ai/DIGEST.md (current project snapshot).
3. Read .ai/TASKS.md (open P-## and E-## tasks).
4. Review the src/ directory structure.

Evaluate:
  - Are implemented features aligned with the blueprint?
  - Are there any orphaned features (built but not in architect.md)?
  - Are any blueprint sections ambiguous or missing implementation detail?
  - What are the top 3 architectural risks?

Output a structured audit to .ai/REVIEWS.md with section:
  [ARCH_AUDIT] YYYY-MM-DD | <findings>"
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GEMINI_PROMPT
      ;;
    *)
      echo "✗ Unknown reviewer: ${who}. Use 'claude' or 'gemini'."
      exit 1
      ;;
  esac
}

do_test() {
  local VIBE=0
  for arg in "$@"; do [[ "$arg" == "--vibe" ]] && VIBE=1; done

  if [[ $VIBE -eq 1 ]]; then
    do_vibe_test
    return
  fi

  # Prefer local bash harness (P-15 / §22); fall back to TestSprite if absent
  if [[ -f "tests/run.sh" ]]; then
    bash tests/run.sh
    return
  fi

  echo "Running automated tests via TestSprite..."
  if ! command -v npx &>/dev/null; then
    echo "✗ npx not found. Please install Node.js."
    exit 1
  fi
  npx testsprite run
}

do_vibe_test() {
  if [[ ! -d ".ai" ]]; then
    echo "✗ No .ai/ directory found. Run: ai init"
    exit 1
  fi

  echo ""
  echo "━━ AI-OS VIBE TEST (Chaos & UX Stress) ━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  # ── Phase 1: UX Review (Gemini — ux_reviewer agent) ─────────────────────
  echo "Phase 1: Visual Audit (ux_reviewer)"
  echo ""

  # Check for Playwright
  if command -v npx &>/dev/null && npx playwright --version &>/dev/null 2>&1; then
    echo "  ✓ Playwright detected — running automated visual audit..."
    echo ""
    echo "  Paste into Gemini (ux_reviewer agent) for full Vibe Report:"
  else
    echo "  ✗ Playwright not installed."
    echo "    Install: npm install -D @playwright/test && npx playwright install"
    echo ""
    echo "  Paste into Gemini (ux_reviewer agent) for manual Vibe Report:"
  fi

  cat <<'UX_PROMPT'

━━ VIBE PROMPT — Gemini (ux_reviewer) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
"You are the UX Reviewer running a Vibe Audit.

1. Start the dev server (check package.json for 'dev' or 'start' script).
2. For each primary screen/route, check:
   - Animation smoothness (no jank, < 16ms frame budget)
   - Cumulative Layout Shift (CLS < 0.1)
   - Color contrast (WCAG AA: 4.5:1 for text)
   - Touch targets (≥ 44×44px)
   - Focus visibility (visible ring on tab)
3. Run Lighthouse audit: Performance ≥ 80, Accessibility ≥ 90.
4. Run Rapid-Click stress: click primary CTA 10× rapidly.

Append a [VIBE_REPORT] YYYY-MM-DD | Score: X/10 to .ai/REVIEWS.md.
Tag [VIBE_BLOCKED] if any P0 issues found."
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

UX_PROMPT

  # ── Phase 2: Chaos Monkey (Claude — chaos_monkey agent) ─────────────────
  echo ""
  echo "Phase 2: Chaos Stress Test (chaos_monkey)"
  echo ""
  echo "  Paste into Claude Code (chaos_monkey agent):"

  cat <<'CHAOS_PROMPT'

━━ CHAOS PROMPT — Claude (chaos_monkey) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
"You are the Chaos Monkey running a stress gate audit.

Verify [SEC_CLEARED] in .ai/LOG.md before proceeding (Tier 3 gate).

Run these chaos tests against the local dev environment:
1. Invalid input injection: empty, oversized (>10KB), special chars (XSS, SQLi, path traversal)
2. Network latency: simulate 5s delay, connection drop, offline mode
3. Rapid-click: 20 clicks on primary CTA in < 2s — check race conditions
4. Concurrent sessions: 3 tabs simultaneously — check state corruption
5. Resource exhaustion: 50MB file upload, 100 rapid API calls

Append [CHAOS_REPORT] YYYY-MM-DD to .ai/REVIEWS.md.
Tag [CHAOS_CLEARED] if no P0s found, [CHAOS_BLOCKED] if P0s exist.
Add the result tag to .ai/LOG.md."
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

CHAOS_PROMPT

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "Both reports must be in .ai/REVIEWS.md before Tier 3 release."
  echo "Required stamps: [VIBE_REPORT] + [CHAOS_CLEARED] + [CRITIC_STAMP]"
  echo ""
}

sync_skills_20() {
  # Copy Skills 2.0 folder-based skills (skill-name/SKILL.md structure)
  local src_dir="$1" dst_dir="$2"
  local count=0
  for skill_dir in "${src_dir}"/*/; do
    if [[ -d "$skill_dir" && -f "${skill_dir}SKILL.md" ]]; then
      local skill_name
      skill_name=$(basename "$skill_dir")
      cp -rf "${skill_dir%/}" "${dst_dir}/"
      count=$((count + 1))
    fi
  done
  # Also copy any remaining legacy flat .md files
  cp -f "${src_dir}"/*.md "${dst_dir}/" 2>/dev/null || true
  echo "  $count Skills 2.0 folder(s) + legacy flat files synced from ${src_dir}"
  # Regenerate _SKILLS_INDEX.md in dst_dir (metadata-only manifest for §29 Level 1 loading)
  _generate_skills_index "${dst_dir}"
}

_generate_skills_index() {
  # Generate _SKILLS_INDEX.md — name + one-line description for each skill.
  # Agents use this for Level 1 (metadata-only) discovery without loading full SKILL.md content.
  local dir="$1"
  local index_file="${dir}/_SKILLS_INDEX.md"
  {
    echo "# Skills Index (metadata-only — §29 JIT Skill Loading)"
    echo "# Use activate_skill(<name>) to load full content."
    echo ""
    # Skills 2.0: folder-based
    for skill_dir in "${dir}"/*/; do
      [[ -d "$skill_dir" && -f "${skill_dir}SKILL.md" ]] || continue
      local name desc
      name=$(basename "$skill_dir")
      desc=$(python3 -c "
import re, sys
try:
    c = open('${skill_dir}SKILL.md').read()
    m = re.match(r'^---\n(.*?)\n---', c, re.DOTALL)
    if m:
        for line in m.group(1).splitlines():
            if line.startswith('description:'):
                print(line.split(':', 1)[1].strip())
                sys.exit(0)
except: pass
print('')
" 2>/dev/null)
      if [[ -n "$desc" ]]; then
        echo "- ${name}: ${desc}"
      else
        echo "- ${name}"
      fi
    done
    # Legacy flat .md files
    for skill_file in "${dir}"/*.md; do
      [[ -f "$skill_file" ]] || continue
      local fname
      fname=$(basename "$skill_file" .md)
      [[ "$fname" == "_SKILLS_INDEX" ]] && continue
      local desc
      desc=$(python3 -c "
import re, sys
try:
    c = open('${skill_file}').read()
    m = re.match(r'^---\n(.*?)\n---', c, re.DOTALL)
    if m:
        for line in m.group(1).splitlines():
            if line.startswith('description:'):
                print(line.split(':', 1)[1].strip())
                sys.exit(0)
except: pass
print('')
" 2>/dev/null)
      if [[ -n "$desc" ]]; then
        echo "- ${fname}: ${desc}"
      else
        echo "- ${fname}"
      fi
    done
  } > "$index_file"
}

do_sync_github() {
  # §28 GitHub Bridge: fetch assigned issues.
  # Usage: ai sync --github [--repo owner/repo] [--limit N]
  local REPO="" LIMIT="20"
  local _args=("$@")
  local i=0
  while [[ $i -lt ${#_args[@]} ]]; do
    case "${_args[$i]}" in
      --repo)  i=$((i+1)); REPO="${_args[$i]}" ;;
      --limit) i=$((i+1)); LIMIT="${_args[$i]}" ;;
    esac
    i=$((i+1))
  done

  if ! command -v gh &>/dev/null; then
    echo "✗ GitHub CLI (gh) not found. Install: https://cli.github.com/"
    return 1
  fi

  if ! gh auth status &>/dev/null 2>&1; then
    echo "✗ GitHub CLI not authenticated. Run: gh auth login"
    return 1
  fi

  if [[ ! -d ".ai" ]]; then
    echo "✗ Not in an AI-OS project — run: ai init"
    return 1
  fi

  echo "Fetching assigned GitHub issues (limit=${LIMIT})..."

  local GH_ARGS=(issue list --assignee @me --state open --limit "$LIMIT" --json "number,title,labels,url,body")
  [[ -n "$REPO" ]] && GH_ARGS+=(-R "$REPO")

  local ISSUES_JSON
  ISSUES_JSON=$(gh "${GH_ARGS[@]}" 2>/dev/null) || { echo "✗ gh issue list failed."; return 1; }

  local DATE
  DATE=$(date '+%Y-%m-%d')

  GITHUB_ISSUES_JSON="$ISSUES_JSON" python3 - "$DATE" <<'PY'
import json, sys, os
date = sys.argv[1]
try:
    issues = json.loads(os.environ.get("GITHUB_ISSUES_JSON", "[]"))
except Exception:
    issues = []
if not issues:
    print("No issues found.")
    sys.exit(0)
header = f"\n## GitHub Issues — imported {date}\n\n"
parts = []
for issue in issues:
    labels = ", ".join(l["name"] for l in issue.get("labels", []))
    block = "\n".join(filter(None, [
        f"### Issue #{issue['number']}: {issue['title']}",
        f"URL: {issue.get('url', '')}",
        f"Labels: {labels}" if labels else None,
        "",
        (issue.get("body") or "(no description)")[:800],
    ]))
    parts.append(block)
footer = "\n## Action Required\nGemini (Architect): Review the issues above and create P-## blueprint tasks via:\n  mcp__task-synchronizer-mcp__add_task({ prefix: 'P', owner: 'Architect (Gemini)', description: '...', tier: N })\nThis writes to state.sqlite and regenerates TASKS.md automatically.\n"
print(header + "\n\n---\n\n".join(parts) + "\n" + footer)
PY

  echo "✓ Issues fetched. Paste the output above into your chat with Gemini to blueprint them."
}

do_sync() {
  # §28: handle --github flag before normal sync
  for arg in "$@"; do
    if [[ "$arg" == "--github" ]]; then
      do_sync_github "$@"
      return
    fi
  done

  # Sync project-scoped dirs only — global ~/.claude and ~/.gemini are user-owned (§21)
  if [[ -d ".ai" ]]; then
    echo "Syncing project-scoped .claude/ and .gemini/ from ${AIOS} ..."

    # Always update bootloaders so skill invocation stays current
    local T="${AIOS}/templates"
    cp -f "$T/CLAUDE.md" "CLAUDE.md" && echo "  CLAUDE.md updated (bootloader)"
    cp -f "$T/GEMINI.md" "GEMINI.md" && echo "  GEMINI.md updated (bootloader)"

    # Always regenerate .mcp.json to pick up new servers (preserves user env values)
    generate_mcp_json "." && echo "  .mcp.json updated (MCP server registry)"

    mkdir -p ".claude/agents" ".claude/skills" ".claude/commands"
    cp -f "${AIOS}/claude/agents/"*.md ".claude/agents/" 2>/dev/null || true
    sync_skills_20 "${AIOS}/shared/skills" ".claude/skills"
    sync_skills_20 "${AIOS}/claude/skills" ".claude/skills"
    _configure_project_claude_settings ".claude"
    echo "  .claude/ synced (agents + skills + _SKILLS_INDEX.md + settings.json)"

    mkdir -p ".gemini/agents" ".gemini/skills"
    cp -f "${AIOS}/gemini/agents/"*.md ".gemini/agents/" 2>/dev/null || true
    strip_gemini_agent_fields ".gemini/agents"
    sync_skills_20 "${AIOS}/shared/skills" ".gemini/skills"
    sync_skills_20 "${AIOS}/gemini/skills" ".gemini/skills"
    _configure_project_gemini_settings ".gemini"
    echo "  .gemini/ synced (agents + skills + _SKILLS_INDEX.md + settings.json)"
  else
    echo "  Not in an AI-OS project (.ai/ not found) — nothing to sync."
    echo "  Run 'ai init' first to scaffold .ai/, .claude/, and .gemini/."
    exit 0
  fi

  cp -f "${AIOS}/hooks/"*.sh "${HOME}/.ai-os/hooks/" 2>/dev/null || true
  chmod +x "${HOME}/.ai-os/hooks/"*.sh 2>/dev/null || true
  echo "  Hooks synced"

  echo "Done."
}

doctor() {
  local REPAIR=0
  local COMPLIANCE=0
  for arg in "$@"; do
    [[ "$arg" == "--repair" ]]     && REPAIR=1
    [[ "$arg" == "--compliance" ]] && COMPLIANCE=1
  done

  # E-109: --compliance audit mode (§32 verification-mcp)
  if [[ "$COMPLIANCE" -eq 1 ]]; then
    _run_compliance_audit
    return 0
  fi

  echo "AI-OS v${VERSION} — doctor${REPAIR:+ (--repair mode)}"
  echo ""

  echo "Install root:  ${AIOS}"
  echo "Bin:           ${AIOS}/bin/ai"
  echo ""

  echo "PATH contains ~/.ai-os/bin?"
  if echo "$PATH" | tr ':' '\n' | grep -q "\.ai-os/bin"; then
    echo "  ✓ yes"
  else
    echo "  ✗ NO — add to shell: export PATH=\"\$HOME/.ai-os/bin:\$PATH\""
  fi
  echo ""

  echo "Gemini (Global — user-owned, not managed by AI-OS):"
  [[ -d "${HOME}/.gemini" ]] && echo "  ✓ ~/.gemini exists" || echo "  ✗ ~/.gemini missing (create with: mkdir -p ~/.gemini)"
  echo ""

  echo "Claude (Global — user-owned, not managed by AI-OS):"
  [[ -d "${HOME}/.claude" ]] && echo "  ✓ ~/.claude exists" || echo "  ✗ ~/.claude missing"
  echo ""

  if [[ -d ".ai" ]]; then
    echo "Project-Scoped (.claude/ / .gemini/):"
    for agent_dir in ".claude" ".gemini"; do
      local scope_label="${agent_dir}"
      if [[ -d "${agent_dir}/agents" ]]; then
        echo "  ✓ ${scope_label}/agents: $(ls "${agent_dir}/agents" | wc -l | tr -d ' ') files"
      else
        echo "  ✗ ${scope_label}/agents: missing — run: ai init"
      fi
      if [[ -d "${agent_dir}/skills" ]]; then
        echo "  ✓ ${scope_label}/skills: $(ls "${agent_dir}/skills" | wc -l | tr -d ' ') entries"
      else
        echo "  ✗ ${scope_label}/skills: missing — run: ai init"
      fi
    done
    echo ""
  fi

  echo "Hooks:"
  if [[ -f "${HOME}/.ai-os/hooks/stop-hook.sh" ]]; then
    echo "  ✓ stop-hook.sh present (auto SESSION stamp)"
  else
    echo "  ✗ stop-hook.sh missing — run: ai install"
  fi
  if [[ -f "${HOME}/.ai-os/hooks/post-tool-log.sh" ]]; then
    echo "  ✓ post-tool-log.sh present (auto LOG append)"
  else
    echo "  ✗ post-tool-log.sh missing — run: ai install"
  fi
  if [[ -f "${HOME}/.ai-os/hooks/post-tool-use.sh" ]]; then
    echo "  ✓ post-tool-use.sh present (AQG: auto test gate)"
  else
    echo "  ✗ post-tool-use.sh missing — run: ai install"
  fi
  if [[ -f "${HOME}/.ai-os/hooks/pre-commit.sh" ]]; then
    echo "  ✓ pre-commit.sh present (Gate 2: Quality Gate)"
  else
    echo "  ✗ pre-commit.sh missing — run: ai install"
  fi
  # Check git hook in current repo
  if git rev-parse --git-dir &>/dev/null; then
    local pc_hook
    pc_hook="$(git rev-parse --git-dir)/hooks/pre-commit"
    if [[ -f "$pc_hook" ]] && grep -q "AI-OS Gate 2" "$pc_hook" 2>/dev/null; then
      echo "  ✓ .git/hooks/pre-commit: Gate 2 installed"
    else
      echo "  ✗ .git/hooks/pre-commit: Gate 2 NOT installed — run: ai init"
    fi
  fi
  echo ""

  echo "settings.json:"
  local settings
  if [[ -d ".ai" && -f ".claude/settings.json" ]]; then
    settings=".claude/settings.json"
    echo "  (Project-Scoped)"
  else
    settings="${HOME}/.claude/settings.json"
    echo "  (Global Fallback)"
  fi
  if [[ -f "$settings" ]]; then
    echo "  ✓ present"
    python3 -c "
import json
with open('$settings') as f:
    d = json.load(f)
env = d.get('env', {})
print('  agent teams:', env.get('CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS', 'NOT SET'))
hooks = d.get('hooks', {})
print('  Stop hook:', 'yes ✓' if hooks.get('Stop') else 'NO - run: ai install')
print('  PostToolUse hook:', 'yes ✓' if hooks.get('PostToolUse') else 'NO - run: ai install')
allow = d.get('permissions', {}).get('allow', [])
broad = [x for x in allow if x == 'Bash(gemini *)']
print('  Gemini perm:', 'BROAD (Bash(gemini *)) - run: ai install to fix' if broad else 'scoped ✓')
" 2>/dev/null || echo "  ✗ could not parse settings.json"
  else
    echo "  ✗ missing — run: ai install"
  fi
  echo ""

  echo "GitHub Copilot CLI:"
  if command -v gh &>/dev/null; then
    echo "  ✓ gh installed: $(gh --version 2>/dev/null | head -1)"
    if gh extension list 2>/dev/null | grep -q "github/gh-copilot"; then
      echo "  ✓ gh copilot extension installed"
    else
      echo "  ✗ gh copilot not installed — run: gh extension install github/gh-copilot"
    fi
  else
    echo "  ✗ gh not installed — run: brew install gh && gh auth login"
  fi
  [[ -f "${HOME}/.config/github-copilot/COPILOT.md" ]] \
    && echo "  ✓ COPILOT.md installed" \
    || echo "  ✗ COPILOT.md missing — run: ai install"
  echo ""

  echo "MCP Servers:"
  if command -v node &>/dev/null; then
    echo "  ✓ node $(node --version) (required for MCP servers)"
  else
    echo "  ✗ node not found — MCP servers need Node.js: brew install node"
  fi
  if command -v npx &>/dev/null; then
    echo "  ✓ npx available"
    if npx testsprite --version &>/dev/null 2>&1; then
      echo "  ✓ TestSprite: available"
    else
      echo "  ✗ TestSprite: not installed — run: npx @testsprite/testsprite-mcp@latest"
    fi
  else
    echo "  ✗ npx not found — install Node.js"
  fi

  # E-34: Per-server health check from registry
  local MCP_DIR="${AIOS}/mcp"
  local REGISTRY="${AIOS}/config/registry.json"
  if [[ -f "$REGISTRY" ]] && command -v python3 &>/dev/null; then
    echo "  Custom MCP servers (registry: ${REGISTRY}):"
    while IFS='|' read -r srv_name _; do
      [[ -z "$srv_name" ]] && continue
      local sdir="${MCP_DIR}/${srv_name}"
      if [[ ! -d "$sdir" ]]; then
        echo "    ✗ ${srv_name}: source missing at ${sdir} — run: ai install"
      elif [[ ! -f "${sdir}/package.json" ]]; then
        echo "    ✗ ${srv_name}: package.json missing"
      elif [[ ! -d "${sdir}/node_modules" ]]; then
        echo "    ✗ ${srv_name}: node_modules missing — run: ai mcp-setup"
      elif [[ ! -f "${sdir}/index.js" ]]; then
        echo "    ✗ ${srv_name}: index.js missing"
      else
        echo "    ✓ ${srv_name}"
      fi
    done < <(python3 -c "
import json
with open('$REGISTRY') as f:
    d = json.load(f)
for name, info in d.get('mcp_servers', {}).items():
    if 'path' in info:
        print(name + '|' + info['path'])
" 2>/dev/null || true)
  fi

  if [[ -f ".mcp.json" ]]; then
    echo "  ✓ .mcp.json present ($(pwd))"
    # Verify absolute paths in .mcp.json are valid
    python3 - <<'PY' 2>/dev/null || true
import json, os
with open(".mcp.json") as f:
    cfg = json.load(f)
broken = []
for name, srv in cfg.get("mcpServers", {}).items():
    for a in srv.get("args", []):
        if a.startswith("/") and not os.path.exists(a):
            broken.append(f"{name}: {a}")
if broken:
    for b in broken:
        print(f"    ✗ broken path — {b} — run: ai mcp-setup")
else:
    print("  ✓ .mcp.json paths: all valid")
PY
  else
    echo "  ✗ .mcp.json not found in $(pwd) — run: ai init"
  fi
  echo ""

  # ── E-63: Deep Audit — Dependency Health + Connectivity Probe ──────────────
  echo "MCP Deep Audit (§19.1):"
  if [[ -f "$REGISTRY" ]] && command -v python3 &>/dev/null && command -v node &>/dev/null; then
    local deep_fail=0
    while IFS='|' read -r srv_name _; do
      [[ -z "$srv_name" ]] && continue
      local sdir="${MCP_DIR}/${srv_name}"
      [[ ! -d "$sdir" ]] && continue  # already reported above

      # Dependency health: npm list --depth=0 (exit code 0 = all satisfied)
      local npm_out
      npm_out=$(cd "$sdir" && npm list --depth=0 2>&1)
      if echo "$npm_out" | grep -q "missing\|UNMET\|invalid"; then
        echo "  ✗ ${srv_name}: dependency issues — run: ai mcp-setup"
        echo "      $(echo "$npm_out" | grep -E 'missing|UNMET|invalid' | head -3 | sed 's/^/      /')"
        deep_fail=1
      fi

      # Connectivity probe: node -c syntax check
      if [[ -f "${sdir}/index.js" ]]; then
        if ! node -c "${sdir}/index.js" &>/dev/null; then
          echo "  ✗ ${srv_name}: index.js syntax error (CRITICAL_FAILURE)"
          deep_fail=1
        fi
      fi

    done < <(python3 -c "
import json
with open('$REGISTRY') as f:
    d = json.load(f)
for name, info in d.get('mcp_servers', {}).items():
    if 'path' in info:
        print(name + '|' + info['path'])
" 2>/dev/null || true)

    # Registry ↔ .mcp.json path consistency check
    if [[ -f ".mcp.json" ]]; then
      python3 - <<'PY' 2>/dev/null || true
import json, os
AIOS = os.path.expanduser("~/.ai-os")
with open(os.path.join(AIOS, "config/registry.json")) as f:
    reg = json.load(f)
with open(".mcp.json") as f:
    mcp = json.load(f)
mcp_servers = mcp.get("mcpServers", {})
for name, info in reg.get("mcp_servers", {}).items():
    if name not in mcp_servers:
        print(f"  ✗ {name}: in registry but missing from .mcp.json — run: ai mcp-setup")
    elif "path" in info:
        args = mcp_servers[name].get("args", [])
        expected = os.path.join(AIOS, "mcp", name, "index.js")
        if args and args[0] != expected:
            print(f"  ✗ {name}: .mcp.json path mismatch")
            print(f"      expected: {expected}")
            print(f"      actual:   {args[0]}")
PY
    fi

    # Check TESTSPRITE_API_KEY is not a literal placeholder
    if [[ -f ".mcp.json" ]] && grep -q '${TESTSPRITE_API_KEY}' .mcp.json 2>/dev/null; then
      if [[ -z "${TESTSPRITE_API_KEY:-}" ]]; then
        echo "  ✗ TESTSPRITE_API_KEY: env var not set — TestSprite MCP will receive literal '\${TESTSPRITE_API_KEY}'"
        echo "      Fix: export TESTSPRITE_API_KEY=<your-key> in ~/.zshrc or ~/.bashrc"
      else
        echo "  ✓ TESTSPRITE_API_KEY: set ($(echo "${TESTSPRITE_API_KEY}" | cut -c1-4)****)"
      fi
    fi

    [[ "$deep_fail" -eq 0 ]] && echo "  ✓ all MCP servers: dependencies OK, syntax OK, paths consistent"
  else
    echo "  — skipped (requires node + python3)"
  fi
  echo ""

  echo "Copilot repo instructions (.github/copilot-instructions.md in current dir):"
  if [[ -f ".github/copilot-instructions.md" ]]; then
    echo "  ✓ present (read automatically by GitHub Copilot Chat)"
  else
    echo "  ✗ not found in $(pwd) — run: ai init to scaffold it"
  fi
  echo ""

  echo "Orphaned v2 contracts (should be gone):"
  for f in 10_WORKFLOW.md 20_OWNERSHIP.md 30_TOKEN_DISCIPLINE.md 40_SECURITY.md 50_DEVOPS.md 60_SEO_COMPLIANCE.md; do
    if [[ -f "${AIOS}/contracts/$f" ]]; then
      echo "  ✗ ORPHAN: ${AIOS}/contracts/$f — run: ai install to remove"
    fi
  done
  echo "  (if nothing listed above, contracts are clean ✓)"
  echo ""

  echo "State Health (.ai/state.json):"
  if [[ -d ".ai" ]] && command -v python3 &>/dev/null; then
    local state_file=".ai/state.json"
    local tasks_file=".ai/TASKS.md"
    if [[ -f "$state_file" ]]; then
      python3 -c "
import json, re, os, sys
state_file = '${state_file}'
tasks_file = '${tasks_file}'
try:
    d = json.load(open(state_file))
    tasks  = d.get('tasks', [])
    stamps = d.get('stamps', [])
    print('  state.json: tasks=' + str(len(tasks)) + ', stamps=' + str(len(stamps)))
    if len(tasks) == 0 and os.path.exists(tasks_file):
        with open(tasks_file) as f:
            content = f.read()
        task_count = len(re.findall(r'^- \[', content, re.MULTILINE))
        if task_count > 0:
            print('  WARN: state.json has 0 tasks but TASKS.md has ' + str(task_count) + ' entries — run: ai migrate-state')
        else:
            print('  state.json and TASKS.md both empty (clean slate)')
    elif len(tasks) > 0:
        print('  state.json v' + str(d.get('version', '?')) + ' — OK')
except Exception as e:
    print('  state.json error: ' + str(e))
" 2>/dev/null || echo "  ✗ could not parse state.json"
    else
      echo "  ✗ state.json missing — run: ai init or ai migrate-state"
    fi
  else
    echo "  — skipped (not in a project dir or python3 missing)"
  fi

  # E-94: --repair mode — fix detected issues automatically
  if [[ "$REPAIR" -eq 1 ]]; then
    echo ""
    echo "Repair Mode — fixing detected issues..."
    echo ""
    local MCP_DIR="${AIOS}/mcp"
    local REGISTRY="${AIOS}/config/registry.json"

    # Re-run npm install for all registered MCP servers with missing/broken deps
    if [[ -f "$REGISTRY" ]] && command -v node &>/dev/null && command -v python3 &>/dev/null; then
      while IFS='|' read -r srv_name _; do
        [[ -z "$srv_name" ]] && continue
        local sdir="${MCP_DIR}/${srv_name}"
        [[ ! -d "$sdir" ]] && continue
        if [[ ! -d "${sdir}/node_modules" ]] || (cd "$sdir" && npm list --depth=0 2>&1 | grep -q "missing\|UNMET\|invalid"); then
          echo "  → npm install: ${srv_name}..."
          (cd "$sdir" && npm install --silent 2>&1) && echo "    ✓ done" || echo "    ✗ failed"
        fi
      done < <(python3 -c "
import json
with open('$REGISTRY') as f:
    d = json.load(f)
for name, info in d.get('mcp_servers', {}).items():
    if 'path' in info:
        print(name + '|' + info['path'])
" 2>/dev/null || true)
    fi

    # Realign .mcp.json if present
    if [[ -f ".mcp.json" ]]; then
      echo "  → realigning .mcp.json..."
      generate_mcp_json && echo "    ✓ .mcp.json realigned" || echo "    ✗ realign failed"
    fi

    echo ""
    echo "Repair complete. Run: ai doctor to verify."
  fi
}

# E-109: Compliance audit — scan agent/skill YAML frontmatter vs registry + .mcp.json (§32)
_run_compliance_audit() {
  local REGISTRY="${AIOS}/config/registry.json"
  echo "AI-OS v${VERSION} — Compliance Audit (§32 Verification)"
  echo ""

  if ! command -v python3 &>/dev/null; then
    echo "✗ python3 required for compliance audit"
    exit 1
  fi

  python3 - "$REGISTRY" "$AIOS" <<'PY'
import json, sys, os, re
from pathlib import Path

registry_path = sys.argv[1]
aios          = sys.argv[2]

# Load registry allowed-tools per server
available_tools = {}
try:
    reg = json.load(open(registry_path))
    for name, info in reg.get("mcp_servers", {}).items():
        tools = info.get("allowed-tools", [])
        if "*" in tools:
            available_tools[name] = "*"
        else:
            for t in tools:
                available_tools[t] = name
except Exception as e:
    print(f"✗ Could not read registry.json: {e}")
    sys.exit(1)

# Also accept built-in Claude tools as valid
BUILTIN_TOOLS = {"Read","Write","Edit","Glob","Grep","Bash","WebSearch","WebFetch",
                 "Agent","TodoRead","TodoWrite","mcp__*"}

def is_available(tool):
    if tool in available_tools:
        return True
    if tool in BUILTIN_TOOLS:
        return True
    if tool == "*":
        return True
    # mcp__ prefix tools — available if the server is in registry
    if tool.startswith("mcp__"):
        return True
    return False

# Scan all agent + skill .md files
search_paths = [
    Path(aios) / "claude" / "agents",
    Path(aios) / "claude" / "skills",
    Path(aios) / "shared" / "skills",
    Path(aios) / "gemini" / "agents",
    Path(aios) / "gemini" / "skills",  # E-116: Gemini skills included in compliance scan
]
# Also scan project-local if we're in an AI-OS project
if Path(".ai").exists():
    search_paths += [
        Path("src/claude/agents"),
        Path("src/claude/skills"),
        Path("src/shared/skills"),
        Path("src/gemini/skills"),
        # E-118: project-scoped dirs (populated by ai init / ai sync)
        Path(".claude/agents"),
        Path(".claude/skills"),
        Path(".gemini/agents"),
        Path(".gemini/skills"),
    ]

violations = []
scanned = 0

for base in search_paths:
    if not base.exists():
        continue
    for md in base.rglob("*.md"):
        text = md.read_text(errors="replace")
        if not text.startswith("---"):
            continue
        # Parse YAML frontmatter
        end = text.find("---", 3)
        if end == -1:
            continue
        frontmatter = text[3:end]
        name_m = re.search(r"^name:\s*(.+)$", frontmatter, re.M)
        tools_m = re.search(r"^allowed-tools:\s*(.+)$", frontmatter, re.M)
        agent_name = name_m.group(1).strip() if name_m else str(md.stem)
        scanned += 1

        if not tools_m:
            violations.append({
                "agent": agent_name,
                "file": str(md),
                "severity": "WARN",
                "issue": "Missing allowed-tools field in frontmatter"
            })
            continue

        declared_tools = [t.strip() for t in tools_m.group(1).split(",")]
        for tool in declared_tools:
            if tool and not is_available(tool):
                violations.append({
                    "agent": agent_name,
                    "file": str(md),
                    "severity": "CRITICAL",
                    "issue": f"Ghost Tool: '{tool}' declared but not in registry or builtin list"
                })

# E-121: ANTI-DRIFT PROTOCOL check — CLAUDE.md and GEMINI.md must contain the header
ANTI_DRIFT_HEADER = "ANTI-DRIFT PROTOCOL"
anti_drift_targets = []
if Path(".ai").exists():
    anti_drift_targets += [Path("CLAUDE.md"), Path("GEMINI.md")]
anti_drift_targets += [Path(aios) / "claude" / "CLAUDE.md",
                       Path(aios) / "gemini" / "GEMINI.md"]
seen_targets = set()
for t in anti_drift_targets:
    if t in seen_targets or not t.exists():
        continue
    seen_targets.add(t)
    content = t.read_text(errors="replace")
    if ANTI_DRIFT_HEADER not in content:
        violations.append({
            "agent": t.name,
            "file": str(t),
            "severity": "CRITICAL",
            "issue": f"Missing ANTI-DRIFT PROTOCOL section (§35) — run: ai sync to update"
        })

print(f"Scanned {scanned} agent/skill files\n")

if not violations:
    print("✓ COMPLIANCE PASS — no Ghost Tools, missing frontmatter, or ANTI-DRIFT violations detected")
else:
    critical = [v for v in violations if v["severity"] == "CRITICAL"]
    warns    = [v for v in violations if v["severity"] == "WARN"]
    print(f"COMPLIANCE REPORT: {len(critical)} CRITICAL | {len(warns)} WARN\n")
    for v in violations:
        icon = "✗" if v["severity"] == "CRITICAL" else "⚠"
        print(f"  {icon} [{v['severity']}] {v['agent']}")
        print(f"      Issue: {v['issue']}")
        print(f"      File:  {v['file']}")
        print()
    if critical:
        print("ACTION REQUIRED: Remove or register Ghost Tools before next commit.")
        sys.exit(1)
PY
}

do_mcp_setup() {
  local MCP_DIR="${AIOS}/mcp"
  local REGISTRY="${AIOS}/config/registry.json"

  if ! command -v node &>/dev/null; then
    echo "✗ Node.js not found — required for MCP servers. Install: brew install node"
    exit 1
  fi

  if [[ ! -d "$MCP_DIR" ]]; then
    echo "✗ MCP servers not found at ${MCP_DIR} — run: ai install"
    exit 1
  fi

  # Read custom server list from registry.json (authoritative whitelist per P-13)
  local CUSTOM_SERVERS=()
  if command -v python3 &>/dev/null && [[ -f "$REGISTRY" ]]; then
    while IFS= read -r srv; do
      [[ -n "$srv" ]] && CUSTOM_SERVERS+=("$srv")
    done < <(python3 -c "
import json, sys
with open('$REGISTRY') as f:
    d = json.load(f)
for name, info in d.get('mcp_servers', {}).items():
    if 'path' in info:
        print(name)
" 2>/dev/null || true)
  fi

  # Fallback if registry parse fails
  if [[ ${#CUSTOM_SERVERS[@]} -eq 0 ]]; then
    CUSTOM_SERVERS=(vibe-check-mcp task-synchronizer-mcp safe-exec-mcp blueprint-aligner-mcp context-guardian-mcp risk-analyzer-mcp)
  fi

  echo "Installing MCP server dependencies from ${MCP_DIR} ..."
  echo ""

  local SETUP_OK=0
  for server in "${CUSTOM_SERVERS[@]}"; do
    local sdir="${MCP_DIR}/${server}"
    if [[ -d "$sdir" && -f "${sdir}/package.json" ]]; then
      echo "  Installing ${server}..."
      (cd "$sdir" && npm install --silent 2>&1 | tail -2) || echo "  ✗ ${server}: npm install failed"
      if [[ "$server" == "vibe-check-mcp" ]]; then
        echo "  Installing Playwright browsers for ${server}..."
        (cd "$sdir" && npx playwright install chromium 2>&1 | tail -2) || true
      fi
      echo "  ✓ ${server}: ready"
      SETUP_OK=$((SETUP_OK + 1))
    else
      echo "  ⚠  ${server}: not found at ${sdir}"
    fi
  done

  echo ""
  echo "✓ MCP setup complete (${SETUP_OK}/${#CUSTOM_SERVERS[@]} servers installed)."

  # E-32: Dynamically regenerate .mcp.json with absolute paths if in a project
  if [[ -d ".ai" || -f ".mcp.json" ]]; then
    generate_mcp_json "."
    echo "✓ .mcp.json regenerated with absolute paths → $(pwd)/.mcp.json"
  fi
  echo "  Registry: ${REGISTRY}"
}

# ── dispatch ──────────────────────────────────────────────────────────────────

cmd="${1:-}"
case "$cmd" in
  install)   install_global ;;
  init)      do_init ;;
  onboard)   do_onboard ;;
  update)    do_update "${@:2}" ;;
  preflight) preflight ;;
  digest)    do_digest ;;
  archive)   do_archive ;;
  review)    do_review "${@:2}" ;;
  test)      do_test "${@:2}" ;;
  sync)          do_sync "${@:2}" ;;
  migrate-state) do_migrate_state "${@:2}" ;;
  mcp-setup)     do_mcp_setup ;;
  doctor)        doctor "${@:2}" ;;
  where)
    echo "AI-OS:     ${AIOS}"
    echo "bin:       ${AIOS}/bin"
    echo "templates: ${AIOS}/templates"
    echo "contracts: ${AIOS}/contracts"
    echo "claude:    ${AIOS}/claude"
    echo "gemini:    ${AIOS}/gemini"
    echo "copilot:   ${AIOS}/copilot"
    echo "hooks:     ${AIOS}/hooks"
    ;;
  version|-v|--version) echo "ai-os ${VERSION}" ;;
  ""|help|-h|--help) usage ;;
  *) echo "Unknown command: $cmd"; usage; exit 1 ;;
esac
