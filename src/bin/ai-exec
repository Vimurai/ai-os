#!/usr/bin/env bash
# ai-exec — AI-OS Execution Gate (E-01)
# Provides git worktree isolation for high-risk tasks.
# Enforces capability isolation: READ (default), WRITE/EXECUTE (require explicit flags).
# Installed to ~/.ai-os/bin/ai-exec

set -euo pipefail

AIOS="${HOME}/.ai-os"
VERSION="1.0"
SCRIPT_NAME="ai-exec"

# ── ANSI colors ───────────────────────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
RESET='\033[0m'

usage() {
  cat <<USAGE
${SCRIPT_NAME} — AI-OS Execution Gate v${VERSION}

Usage:
  ai-exec [OPTIONS] <task-name> -- <command> [args...]

Options:
  --allow-write     Grant WRITE capability (local file edits in worktree)
  --allow-execute   Grant EXECUTE capability (shell command execution; requires SEC_CLEARED)
  --branch <name>   Base branch for the worktree (default: current HEAD)
  --no-worktree     Run without git worktree isolation (READ-only tasks only)
  --dry-run         Print what would happen without executing
  -h, --help        Show this help

Capability tiers:
  READ    — default; filesystem reads, search, analysis (no approval required)
  WRITE   — --allow-write; local file edits isolated in worktree
  EXECUTE — --allow-execute; shell commands; requires [SEC_CLEARED] in LOG.md

Examples:
  ai-exec my-task -- cat src/main.ts
  ai-exec --allow-write refactor-auth -- bash scripts/refactor.sh
  ai-exec --allow-execute --allow-write deploy-task -- npm run build

Security:
  EXECUTE commands trigger Gate 3: LOG.md must contain [SEC_CLEARED] stamp.
  All EXECUTE operations are logged with [SECURITY] prefix.
USAGE
}

# ── helpers ───────────────────────────────────────────────────────────────────

log_security() {
  local msg="$1"
  local log_file
  log_file="$(pwd)/.ai/LOG.md"
  if [[ -f "$log_file" ]]; then
    local ts
    ts=$(date '+%Y-%m-%d %H:%M %Z')
    printf "- %s | Claude | [SECURITY] ai-exec | %s\n" "$ts" "$msg" >> "$log_file"
  fi
}

check_sec_cleared() {
  local log_file
  log_file="$(pwd)/.ai/LOG.md"
  if [[ ! -f "$log_file" ]]; then
    echo -e "${RED}✗ Gate 3 BLOCKED: .ai/LOG.md not found.${RESET}"
    echo "  EXECUTE capability requires [SEC_CLEARED] stamp in LOG.md."
    echo "  Invoke security_engineer (Claude) to perform threat model, then stamp LOG.md."
    return 1
  fi
  # Check for recent [SEC_CLEARED] — within last 50 lines
  if ! tail -50 "$log_file" | grep -q "\[SEC_CLEARED\]"; then
    echo -e "${RED}✗ Gate 3 BLOCKED: No recent [SEC_CLEARED] found in .ai/LOG.md.${RESET}"
    echo ""
    echo -e "${YELLOW}  To unblock EXECUTE:${RESET}"
    echo "  1. Run threat model (security_engineer agent)"
    echo "  2. Add to LOG.md: [SEC_CLEARED] <task-name> — <brief rationale>"
    echo "  3. Re-run ai-exec"
    return 1
  fi
  return 0
}

check_capabilities_md() {
  local caps_file
  caps_file="$(pwd)/.ai/CAPABILITIES.md"
  if [[ ! -f "$caps_file" ]]; then
    echo -e "${YELLOW}⚠  No .ai/CAPABILITIES.md found — using permissive defaults.${RESET}"
    echo "   Run: ai init (or copy ~/.ai-os/templates/CAPABILITIES.md to .ai/)"
    return 0
  fi
  echo -e "${CYAN}  CAPABILITIES.md present — enforcement active.${RESET}"
}

create_worktree() {
  local task_name="$1"
  local base_branch="$2"

  # Ensure we're in a git repo
  if ! git rev-parse --git-dir &>/dev/null; then
    echo -e "${RED}✗ Not a git repository. ai-exec requires git for worktree isolation.${RESET}"
    exit 1
  fi

  local worktree_path
  worktree_path="/tmp/ai-exec-${task_name}-$(date '+%Y%m%d%H%M%S')"

  local branch_name="ai-exec/${task_name}"

  # Check if branch already exists; use a unique suffix if so
  if git branch --list "$branch_name" | grep -q .; then
    branch_name="${branch_name}-$(date '+%H%M%S')"
  fi

  echo -e "${CYAN}  Creating worktree: ${worktree_path}${RESET}"
  echo -e "${CYAN}  Branch: ${branch_name} (based on ${base_branch})${RESET}"

  if ! git worktree add -b "$branch_name" "$worktree_path" "$base_branch" 2>&1; then
    echo -e "${RED}✗ Failed to create git worktree.${RESET}"
    exit 1
  fi

  echo "$worktree_path|$branch_name"
}

remove_worktree() {
  local worktree_path="$1"
  if [[ -d "$worktree_path" ]]; then
    git worktree remove --force "$worktree_path" 2>/dev/null || rm -rf "$worktree_path"
    echo -e "${GREEN}  Worktree cleaned up: ${worktree_path}${RESET}"
  fi
}

# ── main ──────────────────────────────────────────────────────────────────────

ALLOW_WRITE=0
ALLOW_EXECUTE=0
NO_WORKTREE=0
DRY_RUN=0
BASE_BRANCH=""
TASK_NAME=""
CMD_ARGS=()

# Parse arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    --allow-write)    ALLOW_WRITE=1; shift ;;
    --allow-execute)  ALLOW_EXECUTE=1; shift ;;
    --no-worktree)    NO_WORKTREE=1; shift ;;
    --dry-run)        DRY_RUN=1; shift ;;
    --branch)         BASE_BRANCH="$2"; shift 2 ;;
    -h|--help)        usage; exit 0 ;;
    --)               shift; CMD_ARGS=("$@"); break ;;
    -*)               echo "Unknown option: $1"; usage; exit 1 ;;
    *)
      if [[ -z "$TASK_NAME" ]]; then
        TASK_NAME="$1"; shift
      else
        echo "Unexpected argument: $1"; usage; exit 1
      fi
      ;;
  esac
done

if [[ -z "$TASK_NAME" ]]; then
  echo -e "${RED}✗ Task name required.${RESET}"
  usage; exit 1
fi

if [[ ${#CMD_ARGS[@]} -eq 0 ]]; then
  echo -e "${RED}✗ Command required after '--'.${RESET}"
  usage; exit 1
fi

# Resolve base branch
if [[ -z "$BASE_BRANCH" ]]; then
  BASE_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "HEAD")
fi

echo ""
echo -e "${CYAN}━━ AI-OS Execution Gate ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo "   Task:     ${TASK_NAME}"
echo "   Command:  ${CMD_ARGS[*]}"
echo -ne "   Tier:     "

# Determine capability tier and print
if [[ $ALLOW_EXECUTE -eq 1 ]]; then
  echo -e "${RED}EXECUTE (highest risk)${RESET}"
elif [[ $ALLOW_WRITE -eq 1 ]]; then
  echo -e "${YELLOW}WRITE${RESET}"
else
  echo -e "${GREEN}READ (default)${RESET}"
fi

echo ""

# ── Gate 3: EXECUTE check ─────────────────────────────────────────────────────
if [[ $ALLOW_EXECUTE -eq 1 ]]; then
  echo -e "${YELLOW}  Gate 3: Execution Gate — checking [SEC_CLEARED]...${RESET}"
  if ! check_sec_cleared; then
    exit 1
  fi
  echo -e "${GREEN}  Gate 3: CLEARED ✓${RESET}"
  echo ""
fi

# ── CAPABILITIES.md check ────────────────────────────────────────────────────
check_capabilities_md

# ── Dry-run mode ─────────────────────────────────────────────────────────────
if [[ $DRY_RUN -eq 1 ]]; then
  echo ""
  echo -e "${CYAN}  [DRY-RUN] Would execute: ${CMD_ARGS[*]}${RESET}"
  if [[ $NO_WORKTREE -eq 0 ]]; then
    echo -e "${CYAN}  [DRY-RUN] Would create worktree at: /tmp/ai-exec-${TASK_NAME}-<timestamp>${RESET}"
    echo -e "${CYAN}  [DRY-RUN] Would branch from: ${BASE_BRANCH}${RESET}"
  fi
  exit 0
fi

# ── Worktree isolation ───────────────────────────────────────────────────────
WORKTREE_PATH=""
ORIGINAL_DIR="$(pwd)"

if [[ $NO_WORKTREE -eq 0 ]]; then
  echo -e "${CYAN}  Isolating in git worktree...${RESET}"
  WORKTREE_INFO=$(create_worktree "$TASK_NAME" "$BASE_BRANCH")
  WORKTREE_PATH="${WORKTREE_INFO%%|*}"
  WORKTREE_BRANCH="${WORKTREE_INFO##*|}"
  echo ""

  # Ensure cleanup on exit
  trap 'remove_worktree "$WORKTREE_PATH"' EXIT

  cd "$WORKTREE_PATH"
  echo -e "${GREEN}  Working in: ${WORKTREE_PATH}${RESET}"
fi

echo ""
echo -e "${CYAN}━━ Executing ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

# Log EXECUTE operations with [SECURITY] prefix
if [[ $ALLOW_EXECUTE -eq 1 ]]; then
  cd "$ORIGINAL_DIR"
  log_security "EXECUTE | task=${TASK_NAME} | cmd=${CMD_ARGS[*]}"
  [[ -n "$WORKTREE_PATH" ]] && cd "$WORKTREE_PATH"
fi

EXIT_CODE=0
"${CMD_ARGS[@]}" || EXIT_CODE=$?

echo ""
if [[ $EXIT_CODE -eq 0 ]]; then
  echo -e "${GREEN}━━ Done: ${TASK_NAME} exited 0 ✓ ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
else
  echo -e "${RED}━━ Failed: ${TASK_NAME} exited ${EXIT_CODE} ✗ ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
fi

# Log EXECUTE result
if [[ $ALLOW_EXECUTE -eq 1 ]]; then
  cd "$ORIGINAL_DIR"
  log_security "EXECUTE RESULT | task=${TASK_NAME} | exit=${EXIT_CODE}"
  [[ -n "$WORKTREE_PATH" ]] && cd "$WORKTREE_PATH"
fi

exit $EXIT_CODE
