#!/usr/bin/env bash
# ai-watch — Interactive Bridge tmux watcher (E-115, interactive-bridge.md)
#
# Polls .ai/signal.json in the CURRENT project and routes the handoff message to
# the target agent's tmux pane via `tmux send-keys`, enabling the Architect⇄
# Engineer "ping-pong" loop without an API wrapper. The signal is written by the
# task-synchronizer-mcp `handoff_control` tool (E-114).
#
#   target "claude" → the pane titled "claude" (else pane index 0)
#   target "gemini" → the pane titled "gemini" (else pane index 1)
#
# Security:
#   - Isolation: only panes whose pane_current_path is inside THIS project dir
#     are considered, so a watcher never injects into another concurrent project.
#   - Command injection: the message is sent with `send-keys -l --` (literal), so
#     tmux never interprets it as key names and the watcher never evaluates it as
#     shell — it is delivered as typed input to the target REPL.
#
# Rollback: Ctrl-C / kill the process; agents revert to manual keystrokes.
set -uo pipefail

SIGNAL_REL=".ai/signal.json"
POLL_INTERVAL="${AI_WATCH_INTERVAL:-1}"
PROJECT_DIR="$(pwd)"
SIGNAL="${PROJECT_DIR}/${SIGNAL_REL}"

# ── Preconditions ────────────────────────────────────────────────────────────
if ! command -v tmux >/dev/null 2>&1; then
  echo "ai-watch: tmux is not installed — the Interactive Bridge requires tmux." >&2
  exit 1
fi
if ! tmux info >/dev/null 2>&1; then
  echo "ai-watch: not inside a tmux server/session — start tmux first." >&2
  exit 1
fi
if [[ ! -d "${PROJECT_DIR}/.ai" ]]; then
  echo "ai-watch: no .ai/ in ${PROJECT_DIR} — run from an AI-OS project root." >&2
  exit 1
fi
if ! command -v python3 >/dev/null 2>&1; then
  echo "ai-watch: python3 is required to parse the signal." >&2
  exit 1
fi

# ── Helpers ──────────────────────────────────────────────────────────────────
# Emit "<pane_id>\t<pane_index>\t<pane_title>\t<pane_current_path>" for every
# pane, then keep only those rooted in PROJECT_DIR (isolation §Security).
_project_panes() {
  tmux list-panes -a -F '#{pane_id}	#{pane_index}	#{pane_title}	#{pane_current_path}' 2>/dev/null \
    | while IFS=$'\t' read -r pid pidx ptitle ppath; do
        case "$ppath" in
          "$PROJECT_DIR"|"$PROJECT_DIR"/*) printf '%s\t%s\t%s\t%s\n' "$pid" "$pidx" "$ptitle" "$ppath" ;;
        esac
      done
}

# resolve_pane <target> → prints the pane id, or nothing. Prefers a pane titled
# exactly <target>; falls back to the conventional index (claude→0, gemini→1).
resolve_pane() {
  local target="$1" want_idx="" pid pidx ptitle ppath
  case "$target" in claude) want_idx=0 ;; gemini) want_idx=1 ;; *) return 1 ;; esac
  # Pass 1: explicit pane-title match.
  while IFS=$'\t' read -r pid pidx ptitle ppath; do
    [[ "$ptitle" == "$target" ]] && { printf '%s' "$pid"; return 0; }
  done < <(_project_panes)
  # Pass 2: conventional index within this project.
  while IFS=$'\t' read -r pid pidx ptitle ppath; do
    [[ "$pidx" == "$want_idx" ]] && { printf '%s' "$pid"; return 0; }
  done < <(_project_panes)
  return 1
}

_signal_field() {  # _signal_field <key>
  KEY="$1" python3 - "$SIGNAL" <<'PY' 2>/dev/null
import json, os, sys
try:
    print(json.load(open(sys.argv[1])).get(os.environ["KEY"], ""))
except Exception:
    pass
PY
}

_signal_mtime() {
  stat -f %m "$SIGNAL" 2>/dev/null || stat -c %Y "$SIGNAL" 2>/dev/null || echo ""
}

# ── Watch loop ───────────────────────────────────────────────────────────────
echo "ai-watch: watching ${SIGNAL} (poll ${POLL_INTERVAL}s, scoped to ${PROJECT_DIR}) — Ctrl-C to stop."
LAST_MTIME=""
# Don't replay a pre-existing signal on startup — record its mtime first.
[[ -f "$SIGNAL" ]] && LAST_MTIME="$(_signal_mtime)"

while true; do
  if [[ -f "$SIGNAL" ]]; then
    CUR_MTIME="$(_signal_mtime)"
    if [[ -n "$CUR_MTIME" && "$CUR_MTIME" != "$LAST_MTIME" ]]; then
      LAST_MTIME="$CUR_MTIME"
      target="$(_signal_field target)"
      message="$(_signal_field message)"
      if [[ -n "$target" && -n "$message" ]]; then
        pane="$(resolve_pane "$target")"
        if [[ -n "$pane" ]]; then
          # -l: send the message LITERALLY (no tmux key-name interpretation, no
          # shell evaluation here); --: end option parsing so a leading '-' in the
          # message is data. Then submit with Enter.
          tmux send-keys -t "$pane" -l -- "$message"
          tmux send-keys -t "$pane" Enter
          echo "ai-watch: routed → ${target} (${pane}): ${message}"
        else
          echo "ai-watch: no pane for target '${target}' in ${PROJECT_DIR} (need a pane titled '${target}' or at the conventional index)." >&2
        fi
      fi
    fi
  fi
  sleep "$POLL_INTERVAL"
done
